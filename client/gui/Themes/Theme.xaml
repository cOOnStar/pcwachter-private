<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:PCWachter.Desktop.Converters">

  <converters:LessThanConverter x:Key="LessThanConverterTheme"/>

  <!-- Core colors -->
  <Color x:Key="C_AppBg">#0B1220</Color>
  <Color x:Key="C_Surface">#2A313E</Color>
  <Color x:Key="C_NavBg">#262C35</Color>
  <Color x:Key="C_Titlebar">#1F2530</Color>
  <Color x:Key="C_Card">#323A48</Color>
  <Color x:Key="C_Card2">#2F3746</Color>
  <Color x:Key="C_BorderSoft">#3B4557</Color>
  <Color x:Key="C_Accent">#2E7DD2</Color>
  <Color x:Key="C_Accent2">#235FA6</Color>
  <Color x:Key="C_TextPrimary">#EAF2FF</Color>
  <Color x:Key="C_TextSecondary">#A9B7D1</Color>
  <Color x:Key="C_TextMuted">#7E8AA3</Color>
  <Color x:Key="C_Good">#37D67A</Color>
  <Color x:Key="C_Warn">#FFB547</Color>
  <Color x:Key="C_Crit">#FF4D4F</Color>
  <Color x:Key="C_Info">#58A8FF</Color>
  <Color x:Key="C_SkeletonBase">#223248</Color>
  <Color x:Key="C_SkeletonHighlight">#2E435D</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource C_AppBg}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource C_Surface}"/>
  <SolidColorBrush x:Key="NavBgBrush" Color="{StaticResource C_NavBg}"/>
  <SolidColorBrush x:Key="TitlebarBrush" Color="{StaticResource C_Titlebar}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource C_Card}"/>
  <SolidColorBrush x:Key="CardBrush2" Color="{StaticResource C_Card2}"/>
  <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource C_BorderSoft}"/>
  <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource C_BorderSoft}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource C_Accent}"/>
  <SolidColorBrush x:Key="AccentBrush2" Color="{StaticResource C_Accent2}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource C_TextPrimary}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource C_TextSecondary}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource C_TextMuted}"/>
  <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource C_Good}"/>
  <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource C_Warn}"/>
  <SolidColorBrush x:Key="CritBrush" Color="{StaticResource C_Crit}"/>
  <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource C_Info}"/>
  <SolidColorBrush x:Key="SkeletonBaseBrush" Color="{StaticResource C_SkeletonBase}"/>
  <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="{StaticResource C_SkeletonHighlight}"/>

  <!-- Status color system -->
  <SolidColorBrush x:Key="StatusGoodBrush" Color="{StaticResource C_Good}"/>
  <SolidColorBrush x:Key="StatusWarnBrush" Color="{StaticResource C_Warn}"/>
  <SolidColorBrush x:Key="StatusCritBrush" Color="{StaticResource C_Crit}"/>
  <SolidColorBrush x:Key="StatusInfoBrush" Color="{StaticResource C_Info}"/>
  <SolidColorBrush x:Key="StatusGoodBgBrush" Color="#2037D67A"/>
  <SolidColorBrush x:Key="StatusWarnBgBrush" Color="#20FFB547"/>
  <SolidColorBrush x:Key="StatusCritBgBrush" Color="#26FF4D4F"/>
  <SolidColorBrush x:Key="StatusInfoBgBrush" Color="#2458A8FF"/>

  <!-- Spacing scale -->
  <Thickness x:Key="S_4">4</Thickness>
  <Thickness x:Key="S_8">8</Thickness>
  <Thickness x:Key="S_12">12</Thickness>
  <Thickness x:Key="S_16">16</Thickness>
  <Thickness x:Key="S_20">20</Thickness>
  <Thickness x:Key="S_24">24</Thickness>
  <Thickness x:Key="T_WindowMargin">16</Thickness>
  <Thickness x:Key="T_ContentPadding">18</Thickness>
  <Thickness x:Key="T_CardPadding">16</Thickness>

  <CornerRadius x:Key="R_Window">24</CornerRadius>
  <CornerRadius x:Key="R_Card">18</CornerRadius>
  <CornerRadius x:Key="R_Badge">10</CornerRadius>
  <CornerRadius x:Key="R_Pill">14</CornerRadius>

  <!-- Effects -->
  <DropShadowEffect x:Key="ShadowCard" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
  <DropShadowEffect x:Key="ShadowNav" BlurRadius="24" ShadowDepth="0" Opacity="0.25"/>
  <DropShadowEffect x:Key="ShadowOverlay" BlurRadius="28" ShadowDepth="0" Opacity="0.5"/>

  <!-- Typography -->
  <Style x:Key="H1" TargetType="TextBlock">
    <Setter Property="FontSize" Value="28"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="H2" TargetType="TextBlock">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="Body" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
  </Style>

  <Style x:Key="Small" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
  </Style>

  <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource H2}">
    <Setter Property="FontSize" Value="20"/>
  </Style>

  <Style x:Key="MetricValue" TargetType="TextBlock">
    <Setter Property="FontSize" Value="32"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="FocusRing" TargetType="{x:Type Control}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate>
          <Border CornerRadius="8"
                  BorderBrush="#8CB9FF"
                  BorderThickness="1.5"
                  Margin="1"
                  SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Card -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="{DynamicResource R_Card}"/>
    <Setter Property="Padding" Value="{DynamicResource T_CardPadding}"/>
    <Setter Property="Effect" Value="{DynamicResource ShadowCard}"/>
    <Style.Triggers>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource LessThanConverterTheme}, ConverterParameter=1320}" Value="True">
        <Setter Property="Padding" Value="13"/>
        <Setter Property="CornerRadius" Value="14"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualHeight, Converter={StaticResource LessThanConverterTheme}, ConverterParameter=860}" Value="True">
        <Setter Property="Padding" Value="11"/>
        <Setter Property="CornerRadius" Value="12"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- Buttons -->
  <Style x:Key="BtnPrimary" TargetType="Button">
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  CornerRadius="{DynamicResource R_Pill}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="Transparent"
                  BorderThickness="1">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource AccentBrush2}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="#8CB9FF"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualHeight, Converter={StaticResource LessThanConverterTheme}, ConverterParameter=860}" Value="True">
        <Setter Property="Padding" Value="11,8"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource LessThanConverterTheme}, ConverterParameter=1160}" Value="True">
        <Setter Property="Padding" Value="10,7"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="BtnSecondary" TargetType="Button">
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="Background" Value="#3B455740"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  CornerRadius="{DynamicResource R_Pill}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#3B455780"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="#8CB9FF"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualHeight, Converter={StaticResource LessThanConverterTheme}, ConverterParameter=860}" Value="True">
        <Setter Property="Padding" Value="11,8"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource LessThanConverterTheme}, ConverterParameter=1160}" Value="True">
        <Setter Property="Padding" Value="10,7"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="StatusChipBorderStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource StatusInfoBrush}"/>
    <Style.Triggers>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="good">
        <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource StatusGoodBrush}"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="warning">
        <Setter Property="Background" Value="{DynamicResource StatusWarnBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource StatusWarnBrush}"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="critical">
        <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource StatusCritBrush}"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="StatusChipTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
    <Style.Triggers>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="good">
        <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="warning">
        <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="critical">
        <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="PageFilterToggleStyle" TargetType="ToggleButton">
    <Setter Property="Margin" Value="0,0,8,0"/>
    <Setter Property="Padding" Value="10,4"/>
    <Setter Property="Background" Value="#243247"/>
    <Setter Property="BorderBrush" Value="#3D4A61"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="#2B3D56"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.86"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Root" Property="Background" Value="#2E6DB8"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="#69A8F5"/>
              <Setter Property="Foreground" Value="#F1F7FF"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="#8CB9FF"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ToggleButton">
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
  </Style>

  <!-- Dashboard tokens -->
  <LinearGradientBrush x:Key="DashboardHeroGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
    <GradientStop Color="#164A97" Offset="0"/>
    <GradientStop Color="#2370CC" Offset="0.55"/>
    <GradientStop Color="#2C8AF0" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="DashboardPanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#212C3E" Offset="0"/>
    <GradientStop Color="#1B2433" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="DashboardIssueTileBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#2A3447" Offset="0"/>
    <GradientStop Color="#202A3A" Offset="1"/>
  </LinearGradientBrush>

  <Style x:Key="DashboardCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource DashboardPanelBackgroundBrush}"/>
    <Setter Property="CornerRadius" Value="11"/>
    <Setter Property="BorderBrush" Value="#3A465E"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="18"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.34"/>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DashboardPrimaryActionButtonStyle" TargetType="Button">
    <Setter Property="Foreground" Value="#F2F7FF"/>
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="18,11"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" CornerRadius="7">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3493F7" Offset="0"/>
                <GradientStop Color="#1E64C3" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.58"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DashboardSecondaryActionButtonStyle" TargetType="Button">
    <Setter Property="Foreground" Value="#E8EEFA"/>
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="18,11"/>
    <Setter Property="BorderBrush" Value="#4B5771"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Background" Value="#2A3446"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  CornerRadius="7"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="#344057"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.58"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DashboardIssueTileStyle" TargetType="Border">
    <Setter Property="Padding" Value="14"/>
    <Setter Property="Background" Value="{StaticResource DashboardIssueTileBackgroundBrush}"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style x:Key="DashboardMdlIconSmallStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="Foreground" Value="#E8EEFA"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <!-- Legacy nav button style (kept for compatibility) -->
  <Style x:Key="NavButton" TargetType="Button">
    <Setter Property="Margin" Value="6,4"/>
    <Setter Property="Padding" Value="14,12"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="B"
                  CornerRadius="{DynamicResource R_Pill}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="Transparent"
                  BorderThickness="1">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="B" Property="Background" Value="#3B455760"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="B" Property="Background" Value="#3B4557A0"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="B" Property="BorderBrush" Value="#8CB9FF"/>
            </Trigger>
            <Trigger Property="Tag" Value="Selected">
              <Setter TargetName="B" Property="Background" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Badge" TargetType="Border">
    <Setter Property="CornerRadius" Value="{DynamicResource R_Badge}"/>
    <Setter Property="Padding" Value="8,3"/>
    <Setter Property="Background" Value="#3B455780"/>
  </Style>

  <Style x:Key="StatusBadgeGood" TargetType="Border" BasedOn="{StaticResource Badge}">
    <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}"/>
  </Style>

  <Style x:Key="StatusBadgeInfo" TargetType="Border" BasedOn="{StaticResource Badge}">
    <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
  </Style>

  <Style x:Key="StatusBadgeWarn" TargetType="Border" BasedOn="{StaticResource Badge}">
    <Setter Property="Background" Value="{DynamicResource StatusWarnBgBrush}"/>
  </Style>

  <Style x:Key="StatusBadgeCrit" TargetType="Border" BasedOn="{StaticResource Badge}">
    <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
  </Style>

  <Style x:Key="SoftLine" TargetType="Border">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Background" Value="#3B455760"/>
    <Setter Property="Margin" Value="0,10,0,10"/>
  </Style>

  <!-- Compatibility aliases -->
  <Style x:Key="H1Style" TargetType="TextBlock" BasedOn="{StaticResource H1}"/>
  <Style x:Key="BodyStyle" TargetType="TextBlock" BasedOn="{StaticResource Body}"/>
  <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource Card}"/>
  <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BtnPrimary}"/>
  <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BtnSecondary}"/>
  <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButton}"/>

</ResourceDictionary>
