<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="C_AppBg">#111418</Color>
  <Color x:Key="C_Surface">#181C21</Color>
  <Color x:Key="C_NavBg">#14181D</Color>
  <Color x:Key="C_Titlebar">#161A20</Color>
  <Color x:Key="C_Card">#1D2229</Color>
  <Color x:Key="C_Card2">#20262E</Color>
  <Color x:Key="C_BorderSoft">#2D3743</Color>
  <Color x:Key="C_Accent">#4DA3FF</Color>
  <Color x:Key="C_Accent2">#357FD6</Color>
  <Color x:Key="C_TextPrimary">#F3F7FC</Color>
  <Color x:Key="C_TextSecondary">#C2CEDB</Color>
  <Color x:Key="C_TextMuted">#8E9DB0</Color>
  <Color x:Key="C_Good">#4CD08F</Color>
  <Color x:Key="C_Warn">#F5BE5A</Color>
  <Color x:Key="C_Crit">#F07178</Color>
  <Color x:Key="C_Info">#7AB8FF</Color>
  <Color x:Key="C_SkeletonBase">#253040</Color>
  <Color x:Key="C_SkeletonHighlight">#304156</Color>

  <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource C_AppBg}"/>
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource C_AppBg}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource C_Surface}"/>
  <SolidColorBrush x:Key="NavBgBrush" Color="{StaticResource C_NavBg}"/>
  <SolidColorBrush x:Key="TitlebarBrush" Color="{StaticResource C_Titlebar}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource C_Card}"/>
  <SolidColorBrush x:Key="CardBrush2" Color="{StaticResource C_Card2}"/>
  <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource C_BorderSoft}"/>
  <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource C_BorderSoft}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource C_BorderSoft}"/>

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource C_Accent}"/>
  <SolidColorBrush x:Key="AccentBrush2" Color="{StaticResource C_Accent2}"/>
  <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF"/>

  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource C_TextPrimary}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource C_TextSecondary}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource C_TextMuted}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource C_TextPrimary}"/>

  <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#26303B"/>
  <SolidColorBrush x:Key="SurfacePressedBrush" Color="#1E2A3A"/>
  <SolidColorBrush x:Key="SoftPillBrush" Color="#253447"/>
  <SolidColorBrush x:Key="ListSeparatorBrush" Color="#314055"/>

  <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource C_Good}"/>
  <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource C_Warn}"/>
  <SolidColorBrush x:Key="CritBrush" Color="{StaticResource C_Crit}"/>
  <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource C_Info}"/>

  <SolidColorBrush x:Key="StatusGoodBrush" Color="{StaticResource C_Good}"/>
  <SolidColorBrush x:Key="StatusWarnBrush" Color="{StaticResource C_Warn}"/>
  <SolidColorBrush x:Key="StatusCritBrush" Color="{StaticResource C_Crit}"/>
  <SolidColorBrush x:Key="StatusInfoBrush" Color="{StaticResource C_Info}"/>
  <SolidColorBrush x:Key="StatusGoodBgBrush" Color="#224CD08F"/>
  <SolidColorBrush x:Key="StatusWarnBgBrush" Color="#22F5BE5A"/>
  <SolidColorBrush x:Key="StatusCritBgBrush" Color="#24F07178"/>
  <SolidColorBrush x:Key="StatusInfoBgBrush" Color="#227AB8FF"/>

  <SolidColorBrush x:Key="SkeletonBaseBrush" Color="{StaticResource C_SkeletonBase}"/>
  <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="{StaticResource C_SkeletonHighlight}"/>

  <Style x:Key="FluentCardInteractiveStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
  </Style>

  <Style x:Key="FluentChipStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="Background" Value="{DynamicResource SoftPillBrush}"/>
  </Style>

  <Style x:Key="FluentSeparatorStyle" TargetType="Border">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource ListSeparatorBrush}"/>
  </Style>
</ResourceDictionary>
