<UserControl x:Class="PCWachter.Desktop.Views.Pages.AccountPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <controls:SectionHeaderControl Title="Mein Konto" Subtitle="Anmeldung, Lizenz und freigeschaltete Features." />

            <!-- Login / User Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>

                    <!-- Not logged in -->
                    <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="Nicht angemeldet" Style="{StaticResource H2}" FontSize="16"/>
                        <TextBlock Text="Melde dich an um Lizenzen zu aktivieren, Geräte zu verwalten und Cloud-Features zu nutzen."
                                   Style="{StaticResource BodyStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        <Button Content="Mit Browser anmelden"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding LoginCommand}"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Logged in -->
                    <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Avatar -->
                            <Border Width="46" Height="46" CornerRadius="23"
                                    Background="{DynamicResource AccentSubtleBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding UserInitials}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName}" Style="{StaticResource H2}" FontSize="15"/>
                                <TextBlock Text="{Binding UserEmail}" Style="{StaticResource BodyStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Aktualisieren"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding RefreshCommand}"/>
                            <Button Content="Abmelden"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding LogoutCommand}"
                                    Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- License Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Lizenz" Style="{StaticResource H2}" FontSize="16" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Style="{StaticResource SoftLine}" Margin="0,10,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <controls:StatCardControl Grid.Column="0" Title="Plan" Value="{Binding PlanLabel}" Subtitle="{Binding LicenseStateText}"/>
                        <controls:StatCardControl Grid.Column="2" Title="Läuft ab" Value="{Binding ExpiresText}"
                                                  Subtitle="{Binding DaysRemaining, StringFormat='Noch {0} Tage'}"/>
                    </Grid>

                    <!-- Features Grid -->
                    <TextBlock Text="Freigeschaltete Features" Style="{StaticResource BodyStyle}"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,14,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Auto-Fix" Style="{StaticResource BodyStyle}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Margin="0,4,0,0" FontSize="18"
                                           Text="{Binding FeatureAutoFix, Converter={StaticResource BoolToCheckmarkConverter}}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Reports" Style="{StaticResource BodyStyle}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Margin="0,4,0,0" FontSize="18"
                                           Text="{Binding FeatureReports, Converter={StaticResource BoolToCheckmarkConverter}}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Priority Support" Style="{StaticResource BodyStyle}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Margin="0,4,0,0" FontSize="18"
                                           Text="{Binding FeaturePrioritySupport, Converter={StaticResource BoolToCheckmarkConverter}}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Activate License -->
                    <TextBlock Text="Lizenzkey aktivieren" Style="{StaticResource BodyStyle}"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,16,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding ActivateLicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                 Width="280"
                                 Style="{StaticResource TextBoxStyle}"
                                 PlaceholderText="XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"/>
                        <Button Content="Aktivieren"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ActivateLicenseCommand}"
                                Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Status message -->
                    <TextBlock Text="{Binding StatusText}" Margin="0,8,0,0"
                               Style="{StaticResource BodyStyle}"
                               Visibility="{Binding StatusText, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                        <TextBlock.Style>
                            <Style BasedOn="{StaticResource BodyStyle}" TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusIsError}" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
