<UserControl x:Class="PCWachter.Desktop.Views.Pages.StorageFluentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PCWachter.Desktop;component/Themes/Theme.Fluent.Dark.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <LinearGradientBrush x:Key="StorageHeroBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#1A4C7A" Offset="0"/>
        <GradientStop Color="#2166A4" Offset="0.5"/>
        <GradientStop Color="#21436A" Offset="1"/>
      </LinearGradientBrush>

      <Style x:Key="StorageFluentBadgeStyle" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}"/>
        <Style.Triggers>
          <DataTrigger Binding="{Binding StatusLevel}" Value="warning">
            <Setter Property="Background" Value="{DynamicResource StatusWarnBgBrush}"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding StatusLevel}" Value="critical">
            <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding StatusLevel}" Value="unknown">
            <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
          </DataTrigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="StorageFluentBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
        <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
          <DataTrigger Binding="{Binding StatusLevel}" Value="warning">
            <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding StatusLevel}" Value="critical">
            <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding StatusLevel}" Value="unknown">
            <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
          </DataTrigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="DriveTileStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Background" Value="#1C2632"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="#223246"/>
          </Trigger>
          <DataTrigger Binding="{Binding IsSelected}" Value="True">
            <Setter Property="Background" Value="#27415F"/>
            <Setter Property="BorderBrush" Value="#69A8F5"/>
          </DataTrigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="StorageFluentSkeletonBlockStyle" TargetType="Border">
        <Setter Property="Height" Value="14"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
        <Setter Property="Opacity" Value="0.6"/>
        <Style.Triggers>
          <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
              <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0.45"
                                 To="0.82"
                                 Duration="0:0:0.85"/>
              </Storyboard>
            </BeginStoryboard>
          </EventTrigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </UserControl.Resources>

  <Border Background="{DynamicResource AppBgBrush}" DataContext="{Binding HostedContent}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Margin="0,0,0,12"
              Padding="16"
              BorderBrush="#5B8FC4"
              BorderThickness="1"
              CornerRadius="14"
              Background="{StaticResource StorageHeroBrush}">
        <DockPanel LastChildFill="False">
          <StackPanel>
            <TextBlock Text="Speicher Center (Fluent)" Style="{StaticResource H1}" FontSize="26"/>
            <TextBlock Text="Laufwerke, Speicheranalyse und Fixes in einer klaren Arbeitsansicht."
                       Style="{StaticResource BodyStyle}"
                       Foreground="#D3E8FF"/>
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Style="{StaticResource StatusBadgeInfo}" Margin="0,0,8,0">
              <TextBlock Text="{Binding TotalDriveCount, StringFormat=Laufwerke: {0}}"
                         Style="{StaticResource Small}"
                         Foreground="{DynamicResource StatusInfoBrush}"/>
            </Border>
            <Border Style="{StaticResource StatusBadgeWarn}" Margin="0,0,8,0">
              <TextBlock Text="{Binding CriticalDriveCount, StringFormat=Kritisch: {0}}"
                         Style="{StaticResource Small}"
                         Foreground="{DynamicResource StatusWarnBrush}"/>
            </Border>
            <Border Style="{StaticResource StatusBadgeGood}">
              <TextBlock Text="{Binding TotalFreeSpaceText, StringFormat=Frei: {0}}"
                         Style="{StaticResource Small}"
                         Foreground="{DynamicResource StatusGoodBrush}"/>
            </Border>
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.25*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}">
              <DockPanel LastChildFill="False">
                <StackPanel>
                  <TextBlock Text="Laufwerke" Style="{StaticResource SectionTitle}"/>
                  <TextBlock Text="{Binding TotalDiskSpaceText, StringFormat=Gesamtspeicher: {0}}" Style="{StaticResource Small}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Content="Cleanup öffnen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Command="{Binding OpenCleanupCommand}"/>
              </DockPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
              <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260" Visibility="{Binding HasDrives, Converter={StaticResource BoolToVisibilityConverter}}">
                  <ItemsControl ItemsSource="{Binding Drives}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource DriveTileStyle}">
                          <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding DataContext.SelectDriveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"/>
                          </Border.InputBindings>
                          <StackPanel>
                            <DockPanel LastChildFill="False">
                              <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                              <Border DockPanel.Dock="Right" Style="{StaticResource StorageFluentBadgeStyle}">
                                <TextBlock Text="{Binding Status}" Style="{StaticResource StorageFluentBadgeTextStyle}"/>
                              </Border>
                            </DockPanel>
                            <TextBlock Text="{Binding Summary}" Style="{StaticResource BodyStyle}" Margin="0,4,0,0"/>
                            <ProgressBar Value="{Binding UsedPercent}" Maximum="100" Height="8" Margin="0,9,0,0"/>
                            <TextBlock Text="{Binding UsedPercent, StringFormat=Auslastung: {0}%}" Style="{StaticResource Small}" Margin="0,6,0,0"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

                <Border Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderSoftBrush}"
                        BorderThickness="1"
                        Visibility="{Binding HasDrives, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                  <TextBlock Text="Keine Laufwerke gefunden." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                </Border>
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0" Visibility="{Binding HasSelectedDrive, Converter={StaticResource BoolToVisibilityConverter}}">
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <TextBlock Text="{Binding SelectedDrive.Name, StringFormat=Laufwerk {0}}" Style="{StaticResource H2}" FontSize="17"/>
                  <Border DockPanel.Dock="Right" Style="{StaticResource StorageFluentBadgeStyle}" DataContext="{Binding SelectedDrive}">
                    <TextBlock Text="{Binding Status}" Style="{StaticResource StorageFluentBadgeTextStyle}"/>
                  </Border>
                </DockPanel>
                <TextBlock Margin="0,6,0,0" Text="{Binding SelectedDrive.Summary}" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                <TextBlock Margin="0,4,0,0" Text="{Binding SelectedDrive.LastCheckedText}" Style="{StaticResource Small}"/>
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding SelectedDrive.TemperatureText, StringFormat=SMART-Temperatur: {0}}"
                           Style="{StaticResource Small}"
                           Visibility="{Binding SelectedDrive.HasTemperature, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <StackPanel Margin="0,8,0,0" Visibility="{Binding SelectedDrive.HasHealthDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                  <TextBlock Text="SMART-Details" Style="{StaticResource H2}" FontSize="14"/>
                  <ItemsControl ItemsSource="{Binding SelectedDrive.HealthDetails}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                          <TextBlock Text="•" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock Text="{Binding}" Style="{StaticResource Small}" TextWrapping="Wrap"/>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <StackPanel Margin="0,8,0,0" Visibility="{Binding SelectedDrive.HasRecommendations, Converter={StaticResource BoolToVisibilityConverter}}">
                  <TextBlock Text="Empfehlungen" Style="{StaticResource H2}" FontSize="14"/>
                  <ItemsControl ItemsSource="{Binding SelectedDrive.Recommendations}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                          <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" Foreground="{DynamicResource StatusInfoBrush}"/>
                          <TextBlock Text="{Binding}" Style="{StaticResource Small}" TextWrapping="Wrap"/>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
              <StackPanel>
                <TextBlock Text="Speicheranalyse" Style="{StaticResource H2}" FontSize="16"/>
                <TextBlock Text="{Binding StorageAnalysisTotalText, StringFormat=Gesamt erkannt: {0}}" Style="{StaticResource Small}" Margin="0,4,0,0"/>
                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding DownloadsSizeText, StringFormat=Downloads: {0}}" Style="{StaticResource BodyStyle}"/>
                    <TextBlock Text="{Binding TempSizeText, StringFormat=Temp: {0}}" Style="{StaticResource BodyStyle}" Margin="0,4,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding UpdateCacheSizeText, StringFormat=Update-Cache: {0}}" Style="{StaticResource BodyStyle}"/>
                    <TextBlock Text="{Binding RecycleBinSizeText, StringFormat=Papierkorb: {0}}" Style="{StaticResource BodyStyle}" Margin="0,4,0,0"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="Storage-Findings" Style="{StaticResource SectionTitle}"/>
                <WrapPanel Margin="0,8,0,8">
                  <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                Content="{Binding FindingFilterAllLabel}"
                                IsChecked="{Binding IsFindingFilterAllSelected, Mode=OneWay}"
                                Command="{Binding SetFindingFilterCommand}"
                                CommandParameter="all"/>
                  <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                Content="{Binding FindingFilterCriticalLabel}"
                                IsChecked="{Binding IsFindingFilterCriticalSelected, Mode=OneWay}"
                                Command="{Binding SetFindingFilterCommand}"
                                CommandParameter="critical"/>
                  <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                Content="{Binding FindingFilterWarningLabel}"
                                IsChecked="{Binding IsFindingFilterWarningSelected, Mode=OneWay}"
                                Command="{Binding SetFindingFilterCommand}"
                                CommandParameter="warning"/>
                </WrapPanel>

                <ListBox ItemsSource="{Binding StorageFindings}"
                         SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Visibility="{Binding HasStorageFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="Margin" Value="0,0,0,8"/>
                      <Setter Property="Padding" Value="8"/>
                      <Setter Property="Background" Value="#1A2738"/>
                      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
                      <Setter Property="BorderThickness" Value="1"/>
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                  </ListBox.ItemContainerStyle>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <controls:FindingRowControl/>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderSoftBrush}"
                        BorderThickness="1"
                        Visibility="{Binding HasStorageFindings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                  <TextBlock Text="Keine Findings im aktuellen Filter." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                </Border>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
              <Grid>
                <StackPanel Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}}">
                  <TextBlock Text="Quick-Fix" Style="{StaticResource H2}" FontSize="18"/>
                  <TextBlock Text="{Binding SelectedFinding.Title}" Margin="0,8,0,0" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding SelectedFinding.Summary}" Margin="0,6,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding SelectedFinding.CriticalityHint}" Margin="0,6,0,0" Style="{StaticResource Small}" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding SelectedFinding.TimelineText}" Margin="0,8,0,0" Style="{StaticResource Small}"/>
                  <Button Margin="0,12,0,0" Content="Jetzt beheben" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SelectedFinding.RunBestFixCommand}"/>
                  <Button Margin="0,8,0,0" Content="In 24h erinnern" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SelectedFinding.SnoozeOneDayCommand}"/>
                  <Button Margin="0,8,0,0" Content="7 Tage ignorieren" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SelectedFinding.IgnoreForSevenDaysCommand}"/>
                  <Button Margin="0,8,0,0" Content="Details anzeigen" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SelectedFinding.OpenDetailsCommand}"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                  <TextBlock Text="Finding auswählen" FontSize="15" FontWeight="SemiBold" TextAlignment="Center"/>
                  <TextBlock Text="Rechts erscheinen dann Sofortaktionen mit reduziertem Klickweg."
                             Style="{StaticResource BodyStyle}"
                             Margin="0,6,0,0"
                             TextAlignment="Center"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <Grid IsHitTestVisible="False"
            Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
        <StackPanel>
          <Border Style="{StaticResource CardStyle}" Height="86" Margin="0,0,0,12"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.25*"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
              <StackPanel>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Width="140"/>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
              <StackPanel>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Width="180"/>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Height="34" Margin="0,10,0,0"/>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Height="34" Margin="0,8,0,0"/>
                <Border Style="{StaticResource StorageFluentSkeletonBlockStyle}" Height="34" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</UserControl>
