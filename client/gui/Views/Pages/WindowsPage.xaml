<UserControl x:Class="PCWachter.Desktop.Views.Pages.WindowsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
    <UserControl.Resources>
        <Style x:Key="PageFilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#243247"/>
            <Setter Property="BorderBrush" Value="#3D4A61"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3D56"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2E6DB8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#69A8F5"/>
                                <Setter Property="Foreground" Value="#F1F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FindingListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="FindingListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#182536"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E3047"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#244060"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66A8F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowsTrendDeltaStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
            <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHealthTrendPositive}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StartupImpactBadgeStyle" TargetType="Border" BasedOn="{StaticResource Badge}">
            <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Impact}" Value="High">
                    <Setter Property="Background" Value="{DynamicResource StatusWarnBgBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Impact}" Value="Medium">
                    <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Impact}" Value="Low">
                    <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StartupImpactTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Impact}" Value="High">
                    <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Impact}" Value="Low">
                    <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowsSkeletonBlockStyle" TargetType="Border">
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.45"
                                             To="0.82"
                                             Duration="0:0:0.85"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel>
            <controls:SectionHeaderControl Title="Windows"
                                           Subtitle="Reduzierte Ansicht mit Gruppen, Quick-Fix und Gesundheitsverlauf."/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCardControl Title="Windows-Funde" Value="{Binding TotalWindowsFindings}" Subtitle="Gesamt"/>
                <controls:StatCardControl Grid.Column="2" Title="Reboot" Value="{Binding RebootFindingsCount}" Subtitle="Neustart"/>
                <controls:StatCardControl Grid.Column="4" Title="Startup High" Value="{Binding StartupHighImpactCount}" Subtitle="Autostart Impact"/>
                <controls:StatCardControl Grid.Column="6" Title="Sichtbar" Value="{Binding VisibleWindowsFindingsCount}" Subtitle="Nach Filter"/>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Gesundheitsverlauf (7/30/90 Tage)" Style="{StaticResource H2}" FontSize="17"/>
                        <Canvas Height="58" Margin="0,10,0,0">
                            <Polyline Points="{Binding HealthTrendPoints}"
                                      Stroke="#59AEFF"
                                      StrokeThickness="2.4"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                        </Canvas>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,4,0,0">
                        <TextBlock Text="{Binding HealthTrend7AverageText, StringFormat=7T: {0}}" Style="{StaticResource Small}"/>
                        <TextBlock Text="{Binding HealthTrend30AverageText, StringFormat=30T: {0}}" Margin="0,6,0,0" Style="{StaticResource Small}"/>
                        <TextBlock Text="{Binding HealthTrend90AverageText, StringFormat=90T: {0}}" Margin="0,6,0,0" Style="{StaticResource Small}"/>
                        <TextBlock Text="{Binding HealthTrendDeltaText, StringFormat=Delta 30T: {0}}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource WindowsTrendDeltaStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Filter" Style="{StaticResource H2}" FontSize="17"/>
                    <WrapPanel Margin="0,8,0,0">
                        <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                      Content="{Binding FindingFilterAllLabel}"
                                      IsChecked="{Binding IsFindingFilterAllSelected, Mode=OneWay}"
                                      Command="{Binding SetFindingFilterCommand}"
                                      CommandParameter="all"/>
                        <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                      Content="{Binding FindingFilterCriticalLabel}"
                                      IsChecked="{Binding IsFindingFilterCriticalSelected, Mode=OneWay}"
                                      Command="{Binding SetFindingFilterCommand}"
                                      CommandParameter="critical"/>
                        <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                      Content="{Binding FindingFilterWarningLabel}"
                                      IsChecked="{Binding IsFindingFilterWarningSelected, Mode=OneWay}"
                                      Command="{Binding SetFindingFilterCommand}"
                                      CommandParameter="warning"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Autostart Manager" Margin="8,0,0,0" Style="{StaticResource H2}" FontSize="17"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                            <TextBlock Text="{Binding StartupActiveCount, StringFormat=Aktiv: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                        </Border>
                    </DockPanel>

                    <TextBlock Margin="0,4,0,0" Text="{Binding StartupManagerHint}" Style="{StaticResource BodyStyle}"/>
                    <TextBlock Margin="0,2,0,8"
                               Text="{Binding StartupDisabledCount, StringFormat=Bereits deaktiviert durch PCWachter: {0}}"
                               Style="{StaticResource Small}"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <Border Style="{StaticResource SoftLine}" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding StartupEntries}" Visibility="{Binding HasStartupEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10,8"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        Background="#1A2A3D">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <Border Style="{StaticResource StartupImpactBadgeStyle}" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Impact, StringFormat={}{0} Impact}" Style="{StaticResource StartupImpactTextStyle}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding Location, StringFormat=Ort: {0}}"
                                                       Style="{StaticResource Small}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="{Binding CommandLine}"
                                                       Style="{StaticResource Small}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button Content="Deaktivieren"
                                                    MinWidth="120"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.DisableStartupEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding IsDisabledByPcwachter, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                            <Button Content="Rückgängig"
                                                    MinWidth="120"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding DataContext.UndoStartupEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding IsDisabledByPcwachter, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Padding="10"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource BorderSoftBrush}"
                            BorderThickness="1"
                            Visibility="{Binding HasStartupEntries, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="Keine Autostart-Einträge erkannt." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Neustart / Reboot" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding RebootFindings.Count, StringFormat={}{0} Einträge}"
                                                   Style="{StaticResource Small}"
                                                   Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding RebootFindings}"
                                         Style="{StaticResource FindingListBoxStyle}"
                                         ItemContainerStyle="{StaticResource FindingListBoxItemStyle}"
                                         SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                                         Visibility="{Binding HasRebootFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FindingRowControl/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding HasRebootFindings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <TextBlock Text="Keine Reboot-Einträge im aktuellen Filter." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Systemgesundheit" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding HealthFindings.Count, StringFormat={}{0} Einträge}"
                                                   Style="{StaticResource Small}"
                                                   Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding HealthFindings}"
                                         Style="{StaticResource FindingListBoxStyle}"
                                         ItemContainerStyle="{StaticResource FindingListBoxItemStyle}"
                                         SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                                         Visibility="{Binding HasHealthFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FindingRowControl/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding HasHealthFindings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <TextBlock Text="Keine Health-Einträge im aktuellen Filter." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Weitere Hinweise" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding OtherFindings.Count, StringFormat={}{0} Einträge}"
                                                   Style="{StaticResource Small}"
                                                   Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding OtherFindings}"
                                         Style="{StaticResource FindingListBoxStyle}"
                                         ItemContainerStyle="{StaticResource FindingListBoxItemStyle}"
                                         SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                                         Visibility="{Binding HasOtherFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FindingRowControl/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding HasOtherFindings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <TextBlock Text="Keine weiteren Einträge im aktuellen Filter." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <StackPanel Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Quick-Fix" Style="{StaticResource H2}" FontSize="18"/>
                            <TextBlock Text="{Binding SelectedFinding.Title}" Margin="0,8,0,0" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFinding.Summary}" Margin="0,6,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFinding.CriticalityHint}" Margin="0,6,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFinding.TimelineText}" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <Button Margin="0,14,0,0"
                                    Content="Jetzt beheben"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SelectedFinding.RunBestFixCommand}"/>
                            <Button Margin="0,8,0,0"
                                    Content="In 24h erinnern"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectedFinding.SnoozeOneDayCommand}"/>
                            <Button Margin="0,8,0,0"
                                    Content="7 Tage ignorieren"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectedFinding.IgnoreForSevenDaysCommand}"/>
                            <Button Margin="0,8,0,0"
                                    Content="Details anzeigen"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectedFinding.OpenDetailsCommand}"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center"
                                    Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <TextBlock Text="Eintrag aus einer Gruppe auswählen"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextAlignment="Center"/>
                            <TextBlock Text="Rechts erscheinen dann Sofortaktionen mit reduziertem Klickweg."
                                       Margin="0,6,0,0"
                                       Style="{StaticResource BodyStyle}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid IsHitTestVisible="False"
              Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="6" Style="{StaticResource CardStyle}" Height="78"/>
                </Grid>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="18" Width="240"/>
                        <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="58" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="16" Width="90"/>
                        <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="24" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="16" Width="150"/>
                                <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="16" Width="140"/>
                                <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="16" Width="130"/>
                                <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="20" Width="120"/>
                            <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="14" Margin="0,10,0,0"/>
                            <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="14" Margin="0,8,0,0"/>
                            <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="34" Margin="0,14,0,0"/>
                            <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="34" Margin="0,8,0,0"/>
                            <Border Style="{StaticResource WindowsSkeletonBlockStyle}" Height="34" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>



