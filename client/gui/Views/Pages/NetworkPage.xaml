<UserControl x:Class="PCWachter.Desktop.Views.Pages.NetworkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
    <UserControl.Resources>
        <Style x:Key="NetworkStateBadgeStyle" TargetType="Border" BasedOn="{StaticResource Badge}">
            <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NetworkStatus}" Value="Offline">
                    <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NetworkStateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
            <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NetworkStatus}" Value="Offline">
                    <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NetworkSkeletonBlockStyle" TargetType="Border">
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.45"
                                             To="0.82"
                                             Duration="0:0:0.85"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel>
            <controls:SectionHeaderControl Title="Netzwerk" Subtitle="Verbindungsstatus, Adapter und Netzwerk-Findings." />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCardControl Title="Verbindung" Value="{Binding NetworkStatus}" Subtitle="Live-Status"/>
                <controls:StatCardControl Grid.Column="2" Title="Aktive Adapter" Value="{Binding ActiveAdapterCount}" Subtitle="Up/verbunden"/>
                <controls:StatCardControl Grid.Column="4" Title="Netzwerk-Findings" Value="{Binding TotalNetworkFindings}" Subtitle="Offene Einträge"/>
                <controls:StatCardControl Grid.Column="6" Title="Netzlage" Value="{Binding NetworkOverallLabel}" Subtitle="Prioritätsbewertung"/>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Netzwerkstatus" Margin="8,0,0,0" Style="{StaticResource H2}" FontSize="18"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource NetworkStateBadgeStyle}">
                            <TextBlock Text="{Binding NetworkStatus}" Style="{StaticResource NetworkStateTextStyle}"/>
                        </Border>
                    </DockPanel>

                    <TextBlock Margin="0,4,0,0" Text="{Binding NetworkStatusHint}" Style="{StaticResource BodyStyle}"/>
                    <Border Style="{StaticResource SoftLine}" Margin="0,10,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding ActiveAdapterCount, StringFormat=Aktive Adapter: {0}}" Style="{StaticResource BodyStyle}"/>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding AdapterSummary, StringFormat=Adapter: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Margin="0,4,0,0" Text="{Binding GatewayLatencyText, StringFormat=Gateway Latenz: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding PublicDnsLatencyText, StringFormat=Public DNS Latenz: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Margin="0,4,0,0" Text="{Binding ProxyStateText, StringFormat=Proxy: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Quick Fixes" Margin="8,0,0,0" Style="{StaticResource H2}" FontSize="18"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                            <TextBlock Text="Sofortaktionen" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                        </Border>
                    </DockPanel>

                    <TextBlock Margin="0,4,0,0"
                               Text="Bei Verbindungsproblemen zuerst DNS-Cache leeren, dann Proxy prüfen und bei Bedarf Adapter neu starten."
                               Style="{StaticResource BodyStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button MinWidth="170" Command="{Binding FlushDnsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Content" Value="DNS flush"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlushDnsCommand.IsRunning}" Value="True">
                                            <Setter Property="Content" Value="Fuehre aus..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button MinWidth="170" Margin="8,0,0,0" Command="{Binding DisableProxyCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Content" Value="Proxy deaktivieren"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DisableProxyCommand.IsRunning}" Value="True">
                                            <Setter Property="Content" Value="Fuehre aus..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button MinWidth="170" Margin="8,0,0,0" Command="{Binding ResetAdaptersCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Content" Value="Adapter neu starten"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ResetAdaptersCommand.IsRunning}" Value="True">
                                            <Setter Property="Content" Value="Fuehre aus..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Findings" Margin="8,0,0,0" Style="{StaticResource H2}" FontSize="18"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource StatusBadgeInfo}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalNetworkFindings, StringFormat={}{0} Einträge}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                        </Border>
                    </Grid>
                    <TextBlock Margin="0,4,0,0" Text="Sicherheits- und Konnektivitaetshinweise aus den Netzwerkregeln." Style="{StaticResource BodyStyle}"/>
                    <Border Style="{StaticResource SoftLine}" Margin="0,10,0,8"/>

                    <ItemsControl ItemsSource="{Binding NetworkFindings}" Visibility="{Binding HasNetworkFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:FindingCardControl />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Padding="10"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource BorderSoftBrush}"
                            BorderThickness="1"
                            Visibility="{Binding HasNetworkFindings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="Keine Netzwerk-Findings vorhanden." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid IsHitTestVisible="False"
              Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="6" Style="{StaticResource CardStyle}" Height="78"/>
                </Grid>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="18" Width="170"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="12" Width="260" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="1" Margin="0,10,0,8"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="16" Width="220"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="18" Width="120"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="12" Width="340" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="1" Margin="0,10,0,8"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="54"/>
                        <Border Style="{StaticResource NetworkSkeletonBlockStyle}" Height="54" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>


