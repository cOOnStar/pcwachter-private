<UserControl x:Class="PCWachter.Desktop.Views.Pages.SecurityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FindingListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="FindingListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#182536"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E3047"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#244060"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66A8F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CompactFindingTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7" Margin="0,5,8,0" VerticalAlignment="Top"
                         Fill="{Binding Finding.Severity, Converter={StaticResource SeverityToBrushConverter}}"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Summary}" Margin="0,2,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Margin="10,0,0,0" Text="{Binding SeverityText}" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Top"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="SecurityDetailTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root" Background="#1A2739" BorderBrush="#3D4A61" BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#21344C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#F1F7FF"/>
                                <Setter TargetName="Root" Property="Background" Value="#2E6DB8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#69A8F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecuritySkeletonBlockStyle" TargetType="Border">
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.45"
                                             To="0.82"
                                             Duration="0:0:0.85"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Padding="12,10"
                CornerRadius="10"
                BorderBrush="#3A4A61"
                BorderThickness="1"
                Background="#182536"
                Visibility="{Binding ShowSecurityCardSkeletons, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                    <Run Text="Sicherheit"/><Run Text=" &#x2022; "/><Run Text="{Binding SecurityPostureLabel, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding SecurityPostureHint}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}"/>

                <WrapPanel Margin="0,8,0,0">
                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="6" BorderBrush="#4B5E79" BorderThickness="1" Background="#233750">
                        <TextBlock Text="{Binding TotalSecurityFindings, StringFormat=Funde: {0}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                    </Border>
                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="6" BorderBrush="#8A4A4A" BorderThickness="1" Background="#3A2329">
                        <TextBlock Text="{Binding CriticalSecurityCount, StringFormat=Kritisch: {0}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                    </Border>
                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="6" BorderBrush="#8A7440" BorderThickness="1" Background="#3A3121">
                        <TextBlock Text="{Binding WarningSecurityCount, StringFormat=Warnung: {0}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                    </Border>
                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="6" BorderBrush="#3A5B84" BorderThickness="1" Background="#1C2E45">
                        <TextBlock Text="{Binding VisibleSecurityFindingsCount, StringFormat=Sichtbar: {0}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                    </Border>
                </WrapPanel>

                <WrapPanel Margin="0,2,0,0">
                    <Border Margin="0,0,6,6" Style="{StaticResource StatusChipBorderStyle}" Tag="{Binding SmartScreenLevel}">
                        <TextBlock Text="{Binding SmartScreenStatus, StringFormat=SmartScreen: {0}}" Style="{StaticResource StatusChipTextStyle}" Tag="{Binding SmartScreenLevel}"/>
                    </Border>
                    <Border Margin="0,0,6,6" Style="{StaticResource StatusChipBorderStyle}" Tag="{Binding TamperProtectionLevel}">
                        <TextBlock Text="{Binding TamperProtectionStatus, StringFormat=Tamper: {0}}" Style="{StaticResource StatusChipTextStyle}" Tag="{Binding TamperProtectionLevel}"/>
                    </Border>
                    <Border Margin="0,0,6,6" Style="{StaticResource StatusChipBorderStyle}" Tag="{Binding ControlledFolderAccessLevel}">
                        <TextBlock Text="{Binding ControlledFolderAccessStatus, StringFormat=CFA: {0}}" Style="{StaticResource StatusChipTextStyle}" Tag="{Binding ControlledFolderAccessLevel}"/>
                    </Border>
                    <Border Margin="0,0,6,6" Style="{StaticResource StatusChipBorderStyle}" Tag="{Binding ExploitProtectionLevel}">
                        <TextBlock Text="{Binding ExploitProtectionStatus, StringFormat=Exploit: {0}}" Style="{StaticResource StatusChipTextStyle}" Tag="{Binding ExploitProtectionLevel}"/>
                    </Border>
                    <Border Margin="0,0,6,6" Style="{StaticResource StatusChipBorderStyle}" Tag="{Binding LsaProtectionLevel}">
                        <TextBlock Text="{Binding LsaProtectionStatus, StringFormat=LSA: {0}}" Style="{StaticResource StatusChipTextStyle}" Tag="{Binding LsaProtectionLevel}"/>
                    </Border>
                    <Border Margin="0,0,6,6" Style="{StaticResource StatusChipBorderStyle}" Tag="{Binding CredentialGuardLevel}">
                        <TextBlock Text="{Binding CredentialGuardStatus, StringFormat=Credential Guard: {0}}" Style="{StaticResource StatusChipTextStyle}" Tag="{Binding CredentialGuardLevel}"/>
                    </Border>
                </WrapPanel>

                <WrapPanel Margin="0,2,0,0">
                    <ToggleButton Style="{StaticResource PageFilterToggleStyle}" Content="{Binding FindingFilterAllLabel}" IsChecked="{Binding IsFindingFilterAllSelected, Mode=OneWay}" Command="{Binding SetFindingFilterCommand}" CommandParameter="all"/>
                    <ToggleButton Style="{StaticResource PageFilterToggleStyle}" Content="{Binding FindingFilterCriticalLabel}" IsChecked="{Binding IsFindingFilterCriticalSelected, Mode=OneWay}" Command="{Binding SetFindingFilterCommand}" CommandParameter="critical"/>
                    <ToggleButton Style="{StaticResource PageFilterToggleStyle}" Content="{Binding FindingFilterWarningLabel}" IsChecked="{Binding IsFindingFilterWarningSelected, Mode=OneWay}" Command="{Binding SetFindingFilterCommand}" CommandParameter="warning"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Padding="12,10"
                CornerRadius="10"
                BorderBrush="#3A4A61"
                BorderThickness="1"
                Background="#182536"
                IsHitTestVisible="False"
                Visibility="{Binding ShowSecurityCardSkeletons, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="18" Width="240"/>
                <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="12" Width="340" Margin="0,8,0,0"/>
                <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="28" Margin="0,12,0,0"/>
                <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="28" Margin="0,8,0,0"/>
                <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="26" Width="320" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowSecurityCardSkeletons, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Defender" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding DefenderFindings.Count, StringFormat={}{0}}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,6,0,0">
                                <ListBox ItemsSource="{Binding DefenderFindings}" Style="{StaticResource FindingListBoxStyle}" ItemContainerStyle="{StaticResource FindingListBoxItemStyle}" ItemTemplate="{StaticResource CompactFindingTemplate}" SelectedItem="{Binding SelectedFinding, Mode=TwoWay}" Visibility="{Binding HasDefenderFindings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Firewall" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding FirewallFindings.Count, StringFormat={}{0}}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,6,0,0">
                                <ListBox ItemsSource="{Binding FirewallFindings}" Style="{StaticResource FindingListBoxStyle}" ItemContainerStyle="{StaticResource FindingListBoxItemStyle}" ItemTemplate="{StaticResource CompactFindingTemplate}" SelectedItem="{Binding SelectedFinding, Mode=TwoWay}" Visibility="{Binding HasFirewallFindings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="BitLocker" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding BitLockerFindings.Count, StringFormat={}{0}}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,6,0,0">
                                <ListBox ItemsSource="{Binding BitLockerFindings}" Style="{StaticResource FindingListBoxStyle}" ItemContainerStyle="{StaticResource FindingListBoxItemStyle}" ItemTemplate="{StaticResource CompactFindingTemplate}" SelectedItem="{Binding SelectedFinding, Mode=TwoWay}" Visibility="{Binding HasBitLockerFindings, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TabControl Background="Transparent" BorderThickness="0">
                                <TabControl.Resources>
                                    <Style TargetType="TabItem" BasedOn="{StaticResource SecurityDetailTabItemStyle}"/>
                                </TabControl.Resources>

                                <TabItem Header="Übersicht">
                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Text="{Binding SelectedFinding.Title}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedFinding.Summary}" Margin="0,5,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedFinding.CriticalityHint}" Margin="0,6,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedFinding.TimelineText}" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Massnahme">
                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Text="Was ist das?" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFinding.WhatIsThisText}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                        <TextBlock Text="Warum wichtig?" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFinding.WhyImportantText}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                        <TextBlock Text="Empfohlenes Vorgehen" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFinding.RecommendedActionText}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                        <TextBlock Text="Risiko / Aufwand" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFinding.RiskEffortText}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                        <Button Margin="0,12,0,0" Content="Jetzt beheben" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SelectedFinding.RunBestFixCommand}"/>
                                        <Button Margin="0,6,0,0" Content="In 24h erinnern" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SelectedFinding.SnoozeOneDayCommand}"/>
                                        <Button Margin="0,6,0,0" Content="7 Tage ignorieren" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SelectedFinding.IgnoreForSevenDaysCommand}"/>
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Verlauf">
                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Text="Priorisierung" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFinding.PriorityText}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}"/>
                                        <TextBlock Text="Status-Badge" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFinding.BadgeText}" Margin="0,2,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                        </Grid>

                        <StackPanel VerticalAlignment="Center" Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <TextBlock Text="Eintrag auswählen" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center"/>
                            <TextBlock Text="Rechts erscheinen Übersicht, Massnahme und Verlauf als Tabs." Margin="0,5,0,0" Style="{StaticResource BodyStyle}" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="1"
              IsHitTestVisible="False"
              Visibility="{Binding ShowSecurityCardSkeletons, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="16" Width="120"/>
                        <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="48" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="16" Width="110"/>
                        <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="48" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="16" Width="120"/>
                        <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="48" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="28" Width="240"/>
                    <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="14" Margin="0,12,0,0"/>
                    <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="14" Margin="0,8,0,0"/>
                    <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="14" Margin="0,8,0,0"/>
                    <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="34" Margin="0,14,0,0"/>
                    <Border Style="{StaticResource SecuritySkeletonBlockStyle}" Height="34" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

