<UserControl x:Class="PCWachter.Desktop.Views.Pages.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
    <UserControl.Resources>
        <Style x:Key="HistoryFilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#243247"/>
            <Setter Property="BorderBrush" Value="#3D4A61"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3D56"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2E6DB8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#69A8F5"/>
                                <Setter Property="Foreground" Value="#F1F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistorySkeletonBlockStyle" TargetType="Border">
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.45"
                                             To="0.82"
                                             Duration="0:0:0.85"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel>
            <controls:SectionHeaderControl Title="Verlauf / Historie" Subtitle="Remediation, Audit und Bereich." />

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Bereich" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Update-Verlauf und Fehlerdiagnose zentral im Bereich."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyStyle}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Fehlerdiagnose" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right"
                                            Padding="8,3"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            Background="{DynamicResource StatusCritBgBrush}"
                                            BorderBrush="{DynamicResource StatusCritBrush}">
                                        <TextBlock Text="{Binding UpdateDiagnosticsCount, StringFormat={}{0}}"
                                                   Foreground="{DynamicResource StatusCritBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"/>
                                    </Border>
                                </DockPanel>

                                <ItemsControl Margin="0,8,0,0"
                                              ItemsSource="{Binding UpdateDiagnostics}"
                                              Visibility="{Binding HasUpdateDiagnostics, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding Source}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="6,2"
                                                                CornerRadius="6"
                                                                BorderThickness="1"
                                                                Background="{DynamicResource StatusCritBgBrush}"
                                                                BorderBrush="{DynamicResource StatusCritBrush}">
                                                            <TextBlock Text="Fehler"
                                                                       Foreground="{DynamicResource StatusCritBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Message}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Hint}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding TimestampText, StringFormat=Zeit: {0}}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding UpdateDiagnosticsEmptyText}"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="{Binding HasUpdateDiagnostics, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Update-Verlauf" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right"
                                            Padding="8,3"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            Background="{DynamicResource StatusInfoBgBrush}"
                                            BorderBrush="{DynamicResource StatusInfoBrush}">
                                        <TextBlock Text="{Binding UpdateHistoryCount, StringFormat={}{0}}"
                                                   Foreground="{DynamicResource StatusInfoBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"/>
                                    </Border>
                                </DockPanel>

                                <ScrollViewer Margin="0,8,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="240"
                                              Visibility="{Binding HasUpdateHistory, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding UpdateHistory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Details}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding TimestampText, StringFormat=Zeit: {0}}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" HorizontalAlignment="Right">
                                                            <Border Padding="6,2" CornerRadius="6" BorderThickness="1">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource StatusInfoBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource StatusCritBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock Text="{Binding Source}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Text="{Binding UpdateHistoryEmptyText}"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="{Binding HasUpdateHistory, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Remediation-Warteschlange" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Zeigt laufende und zuletzt abgeschlossene Aktionen mit Fortschritt."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyStyle}" />

                    <ItemsControl ItemsSource="{Binding RemediationQueue}"
                                  Visibility="{Binding HasRemediationQueue, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ActionId}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Message}" Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            <ProgressBar Height="6" Margin="0,7,0,0" Minimum="0" Maximum="100" Value="{Binding Percent}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Percent, StringFormat={}{0}%}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding UpdatedAtText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Visibility="{Binding HasRemediationQueue, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="Keine laufenden Aktionen in der Warteschlange."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Auto-Fix Audit-Log" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <WrapPanel Margin="0,10,0,10">
                        <ToggleButton Style="{StaticResource HistoryFilterToggleStyle}"
                                      Content="{Binding AuditFilterAllLabel}"
                                      IsChecked="{Binding IsAuditFilterAllSelected, Mode=OneWay}"
                                      Command="{Binding SetAuditFilterCommand}"
                                      CommandParameter="all" />
                        <ToggleButton Style="{StaticResource HistoryFilterToggleStyle}"
                                      Content="{Binding AuditFilterSuccessLabel}"
                                      IsChecked="{Binding IsAuditFilterSuccessSelected, Mode=OneWay}"
                                      Command="{Binding SetAuditFilterCommand}"
                                      CommandParameter="success" />
                        <ToggleButton Style="{StaticResource HistoryFilterToggleStyle}"
                                      Content="{Binding AuditFilterErrorLabel}"
                                      IsChecked="{Binding IsAuditFilterErrorSelected, Mode=OneWay}"
                                      Command="{Binding SetAuditFilterCommand}"
                                      CommandParameter="error" />
                    </WrapPanel>

                    <ItemsControl ItemsSource="{Binding FilteredAutoFixLogs}"
                                  Visibility="{Binding HasFilteredAutoFixLogs, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding FindingTitle}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding FindingId}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" />
                                            <TextBlock Text="{Binding ActionId, StringFormat=Aktion: {0}}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding Message}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding RollbackHint}"
                                                       Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding RollbackHint, Converter={StaticResource StringToVisibilityConverter}}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                                            <Border Padding="8,3" CornerRadius="6" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource StatusInfoBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ResultLevel}" Value="success">
                                                                <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource StatusGoodBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ResultLevel}" Value="critical">
                                                                <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource StatusCritBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ResultText}" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ResultLevel}" Value="success">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ResultLevel}" Value="critical">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding SeverityText}" Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding TimestampText}" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                                            <Button Margin="0,8,0,0"
                                                    Padding="8,3"
                                                    Content="Rollback"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Command="{Binding DataContext.RollbackActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ActionExecutionId}"
                                                    Visibility="{Binding CanRollback, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Visibility="{Binding HasFilteredAutoFixLogs, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="{Binding AuditEmptyText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Timeline" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Chronologischer Verlauf von Erkennung, Behebung, Konfigurationsaenderungen und Rollbacks."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyStyle}" />

                    <ItemsControl ItemsSource="{Binding TimelineEvents}"
                                  Visibility="{Binding HasTimelineEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="5" Margin="0,0,10,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource StatusInfoBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="success">
                                                            <Setter Property="Background" Value="{DynamicResource StatusGoodBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="warning">
                                                            <Setter Property="Background" Value="{DynamicResource StatusWarnBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="critical">
                                                            <Setter Property="Background" Value="{DynamicResource StatusCritBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Message}" Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding FindingId, StringFormat=Finding: {0}}" Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                       Visibility="{Binding FindingId, Converter={StaticResource StringToVisibilityConverter}}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding TimestampText}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Visibility="{Binding HasTimelineEvents, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="{Binding TimelineEmptyText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Gerade behoben" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <ItemsControl ItemsSource="{Binding RecentlyResolvedFindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:FindingCardControl />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid IsHitTestVisible="False"
              Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="18" Width="260"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="12" Width="320" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="58" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="18" Width="170"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="24" Margin="0,10,0,0"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="58" Margin="0,10,0,0"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="58" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="18" Width="110"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="12" Width="360" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="58" Margin="0,10,0,0"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="58" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="18" Width="150"/>
                        <Border Style="{StaticResource HistorySkeletonBlockStyle}" Height="52" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
