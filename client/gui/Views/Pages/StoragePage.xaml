<UserControl x:Class="PCWachter.Desktop.Views.Pages.StoragePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
    <UserControl.Resources>
        <Style x:Key="StorageStatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource Badge}">
            <Setter Property="Background" Value="{DynamicResource StatusGoodBgBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusLevel}" Value="warning">
                    <Setter Property="Background" Value="{DynamicResource StatusWarnBgBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="critical">
                    <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="unknown">
                    <Setter Property="Background" Value="{DynamicResource StatusInfoBgBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StorageStatusTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
            <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusLevel}" Value="warning">
                    <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="critical">
                    <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="unknown">
                    <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StorageProgressStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusLevel}" Value="warning">
                    <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="critical">
                    <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="unknown">
                    <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PageFilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#243247"/>
            <Setter Property="BorderBrush" Value="#3D4A61"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3D56"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2E6DB8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#69A8F5"/>
                                <Setter Property="Foreground" Value="#F1F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FindingListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="FindingListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#182536"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E3047"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#244060"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66A8F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StorageSkeletonBlockStyle" TargetType="Border">
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.45"
                                             To="0.82"
                                             Duration="0:0:0.85"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DriveCardStyle" TargetType="Border">
            <Setter Property="Width" Value="270"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Background" Value="#283246"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3A53"/>
                    <Setter Property="BorderBrush" Value="#5076A5"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#2E4462"/>
                    <Setter Property="BorderBrush" Value="#69A8F5"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel>
            <controls:SectionHeaderControl Title="Speicher"
                                           Subtitle="Laufwerke und Findings in reduzierter Unterseiten-Ansicht." />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCardControl Title="Laufwerke" Value="{Binding TotalDriveCount}" Subtitle="Fixed Drives"/>
                <controls:StatCardControl Grid.Column="2" Title="Kritisch" Value="{Binding CriticalDriveCount}" Subtitle="Sehr wenig frei"/>
                <controls:StatCardControl Grid.Column="4" Title="Freier Speicher" Value="{Binding TotalFreeSpaceText}" Subtitle="Gesamt frei"/>
                <controls:StatCardControl Grid.Column="6" Title="Storage-Funde" Value="{Binding TotalStorageFindings}" Subtitle="Gesamt"/>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Laufwerke" Style="{StaticResource H2}" FontSize="18"/>
                        <TextBlock Text="{Binding TotalDiskSpaceText, StringFormat=Gesamtspeicher: {0}}" Margin="0,4,0,0" Style="{StaticResource BodyStyle}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Cleanup öffnen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6"
                            Command="{Binding OpenCleanupCommand}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Was frisst Platz" Margin="8,0,0,0" Style="{StaticResource H2}" FontSize="17"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                <TextBlock Text="{Binding StorageAnalysisTotalText, StringFormat=Summe: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                            </Border>
                        </DockPanel>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding DownloadsSizeText, StringFormat=Downloads: {0}}" Style="{StaticResource BodyStyle}"/>
                                <TextBlock Margin="0,4,0,0" Text="{Binding TempSizeText, StringFormat=Temp: {0}}" Style="{StaticResource BodyStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding UpdateCacheSizeText, StringFormat=Update-Cache: {0}}" Style="{StaticResource BodyStyle}"/>
                                <TextBlock Margin="0,4,0,0" Text="{Binding RecycleBinSizeText, StringFormat=Papierkorb: {0}}" Style="{StaticResource BodyStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,10,0,0"
                                Padding="8"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                Visibility="{Binding HasStorageBreakdown, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <TextBlock Text="Noch keine Breakdown-Daten vom Service vorhanden." Style="{StaticResource Small}" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Top Verbraucher" Style="{StaticResource H2}" FontSize="17"/>
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding TopConsumers}" Visibility="{Binding HasTopConsumers, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="8,6"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource BorderSoftBrush}"
                                            BorderThickness="1"
                                            Background="#1A2A3D">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource Small}" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SizeText}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Padding="8"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                Visibility="{Binding HasTopConsumers, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <TextBlock Text="Keine Top-Verbraucher verfügbar." Style="{StaticResource Small}" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Drives}" Visibility="{Binding HasDrives, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DriveCardStyle}">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.SelectDriveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Border DockPanel.Dock="Right" Style="{StaticResource StorageStatusBadgeStyle}">
                                                        <TextBlock Text="{Binding Status}" Style="{StaticResource StorageStatusTextStyle}"/>
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource BodyStyle}" Margin="0,6,0,0"/>
                                                <ProgressBar Style="{StaticResource StorageProgressStyle}" Value="{Binding UsedPercent}" Maximum="100" Height="8" Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding UsedPercent, StringFormat=Auslastung: {0}%}" Margin="0,8,0,0" Style="{StaticResource Small}"/>
                                                <TextBlock Text="{Binding LastCheckedText}" Margin="0,4,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Padding="10"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding HasDrives, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="Keine lokalen Laufwerke gefunden." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <Grid>
                            <StackPanel Visibility="{Binding HasSelectedDrive, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding SelectedDrive.Name, StringFormat=Laufwerk {0}}" Style="{StaticResource H2}" FontSize="17"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StorageStatusBadgeStyle}" DataContext="{Binding SelectedDrive}">
                                        <TextBlock Text="{Binding Status}" Style="{StaticResource StorageStatusTextStyle}"/>
                                    </Border>
                                </DockPanel>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SelectedDrive.Summary}" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedDrive.LastCheckedText}" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>

                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SelectedDrive.TemperatureText, StringFormat=SMART-Temperatur: {0}}"
                                           Style="{StaticResource BodyStyle}"
                                           Visibility="{Binding SelectedDrive.HasTemperature, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <StackPanel Margin="0,10,0,0" Visibility="{Binding SelectedDrive.HasHealthDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="SMART-Details" Style="{StaticResource H2}" FontSize="14"/>
                                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding SelectedDrive.HealthDetails}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="&#x2022;" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource Small}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0" Visibility="{Binding SelectedDrive.HasRecommendations, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Empfehlungen" Style="{StaticResource H2}" FontSize="14"/>
                                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding SelectedDrive.Recommendations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource StatusInfoBrush}" Margin="0,1,6,0"/>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource Small}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Center"
                                        Visibility="{Binding HasSelectedDrive, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="Laufwerk wählen"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Klicken Sie auf eine Laufwerkskarte, um SMART-Details und Empfehlungen zu sehen."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Filter für Storage-Findings" Style="{StaticResource H2}" FontSize="16"/>
                            <WrapPanel Margin="0,8,0,0">
                                <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                              Content="{Binding FindingFilterAllLabel}"
                                              IsChecked="{Binding IsFindingFilterAllSelected, Mode=OneWay}"
                                              Command="{Binding SetFindingFilterCommand}"
                                              CommandParameter="all"/>
                                <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                              Content="{Binding FindingFilterCriticalLabel}"
                                              IsChecked="{Binding IsFindingFilterCriticalSelected, Mode=OneWay}"
                                              Command="{Binding SetFindingFilterCommand}"
                                              CommandParameter="critical"/>
                                <ToggleButton Style="{StaticResource PageFilterToggleStyle}"
                                              Content="{Binding FindingFilterWarningLabel}"
                                              IsChecked="{Binding IsFindingFilterWarningSelected, Mode=OneWay}"
                                              Command="{Binding SetFindingFilterCommand}"
                                              CommandParameter="warning"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Storage-Findings" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeInfo}">
                                        <TextBlock Text="{Binding StorageFindings.Count, StringFormat={}{0} Einträge}"
                                                   Style="{StaticResource Small}"
                                                   Foreground="{DynamicResource StatusInfoBrush}"/>
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding StorageFindings}"
                                         Style="{StaticResource FindingListBoxStyle}"
                                         ItemContainerStyle="{StaticResource FindingListBoxItemStyle}"
                                         SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                                         Visibility="{Binding HasStorageFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FindingRowControl/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding HasStorageFindings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <TextBlock Text="Keine Storage-Findings im aktuellen Filter." Style="{StaticResource BodyStyle}" TextAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <StackPanel Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Quick-Fix" Style="{StaticResource H2}" FontSize="18"/>
                            <TextBlock Text="{Binding SelectedFinding.Title}" Margin="0,8,0,0" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFinding.Summary}" Margin="0,6,0,0" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFinding.CriticalityHint}" Margin="0,6,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFinding.TimelineText}" Margin="0,8,0,0" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <Button Margin="0,14,0,0"
                                    Content="Jetzt beheben"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SelectedFinding.RunBestFixCommand}"/>
                            <Button Margin="0,8,0,0"
                                    Content="In 24h erinnern"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectedFinding.SnoozeOneDayCommand}"/>
                            <Button Margin="0,8,0,0"
                                    Content="7 Tage ignorieren"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectedFinding.IgnoreForSevenDaysCommand}"/>
                            <Button Margin="0,8,0,0"
                                    Content="Details anzeigen"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectedFinding.OpenDetailsCommand}"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center"
                                    Visibility="{Binding HasSelectedFinding, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <TextBlock Text="Storage-Finding auswählen"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextAlignment="Center"/>
                            <TextBlock Text="Rechts erscheinen dann Sofortaktionen mit reduziertem Klickweg."
                                       Margin="0,6,0,0"
                                       Style="{StaticResource BodyStyle}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid IsHitTestVisible="False"
              Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Height="78"/>
                    <Border Grid.Column="6" Style="{StaticResource CardStyle}" Height="78"/>
                </Grid>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="18" Width="120"/>
                        <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="12" Width="220" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="30" Width="150" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="104"/>
                                <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="104" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="16" Width="180"/>
                                <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="24" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="16" Width="140"/>
                                <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="54" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="20" Width="120"/>
                            <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="14" Margin="0,10,0,0"/>
                            <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="14" Margin="0,8,0,0"/>
                            <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="34" Margin="0,14,0,0"/>
                            <Border Style="{StaticResource StorageSkeletonBlockStyle}" Height="34" Margin="0,8,0,0"/>
