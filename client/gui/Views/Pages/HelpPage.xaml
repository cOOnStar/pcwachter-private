<UserControl x:Class="PCWachter.Desktop.Views.Pages.HelpPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
    <UserControl.Resources>
        <Style x:Key="HelpStatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeGood}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ServiceCheckIsError}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource StatusCritBgBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HelpStatusBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Small}">
            <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ServiceCheckIsError}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HelpSkeletonBlockStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource SkeletonBaseBrush}"/>
            <Setter Property="Opacity" Value="0.58"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.42"
                                             To="0.82"
                                             Duration="0:0:0.9"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel>
            <controls:SectionHeaderControl Title="Hilfe" Subtitle="Support, Diagnose und schnelle Serviceaktionen." />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCardControl Title="Servicezustand" Value="{Binding ServiceStateLabel}" Subtitle="Letzter Check"/>
                <controls:StatCardControl Grid.Column="2" Title="Letzter Check" Value="{Binding LastCheckText}" Subtitle="Lokale Zeit"/>
                <controls:StatCardControl Grid.Column="4" Title="Version" Value="{Binding VersionText}" Subtitle="Desktop Build"/>
                <controls:StatCardControl Grid.Column="6" Title="Tools" Value="3" Subtitle="Logs, Check, README"/>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Service und Logs" Margin="8,0,0,0" Style="{StaticResource H2}" FontSize="18"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource HelpStatusBadgeStyle}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ServiceStateLabel}" Style="{StaticResource HelpStatusBadgeTextStyle}"/>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding ServiceCheckStatus}"
                               Style="{StaticResource BodyStyle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenLogsCommand}"
                                Content="Logs öffnen" />

                        <Button MinWidth="180" Command="{Binding CheckServiceStatusCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Content" Value="Service Status prüfen"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CheckServiceStatusCommand.IsRunning}" Value="True">
                                            <Setter Property="Content" Value="Prüfe..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenDesktopReadmeCommand}"
                                Content="Desktop README" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Was tun bei Problemen?" Style="{StaticResource H2}" FontSize="18"/>
                    <Border Style="{StaticResource SoftLine}" Margin="0,10,0,8"/>
                    <TextBlock Text="1. Service Status prüfen und neue Scan-Session starten." Style="{StaticResource BodyStyle}"/>
                    <TextBlock Text="2. Logs öffnen und letzte Fehlerzeit vergleichen." Style="{StaticResource BodyStyle}" Margin="0,6,0,0"/>
                    <TextBlock Text="3. Bei Bedarf Demo-Modus in Optionen aktivieren, um UI getrennt von der API zu testen." Style="{StaticResource BodyStyle}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      IsHitTestVisible="False"
                      Visibility="{Binding DataContext.IsConnectingToService, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="88"/>

                <Grid Margin="0,12,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource HelpSkeletonBlockStyle}" Height="82"/>
                    <Border Grid.Column="2" Style="{StaticResource HelpSkeletonBlockStyle}" Height="82"/>
                    <Border Grid.Column="4" Style="{StaticResource HelpSkeletonBlockStyle}" Height="82"/>
                    <Border Grid.Column="6" Style="{StaticResource HelpSkeletonBlockStyle}" Height="82"/>
                </Grid>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="22" Width="210"/>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="14" Width="420" Margin="0,8,0,0"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource HelpSkeletonBlockStyle}" Height="34"/>
                            <Border Grid.Column="2" Style="{StaticResource HelpSkeletonBlockStyle}" Height="34"/>
                            <Border Grid.Column="4" Style="{StaticResource HelpSkeletonBlockStyle}" Height="34"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="20" Width="240"/>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="1" Margin="0,10,0,10"/>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="14"/>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="14" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource HelpSkeletonBlockStyle}" Height="14" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>


