<UserControl x:Class="PCWachter.Desktop.Views.Pages.UpdatesFluentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PCWachter.Desktop;component/Themes/Theme.Fluent.Dark.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <LinearGradientBrush x:Key="UpdateHeroBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#1A4F93" Offset="0"/>
        <GradientStop Color="#2A72C7" Offset="0.5"/>
        <GradientStop Color="#19497E" Offset="1"/>
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="UpdatePanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1C2638" Offset="0"/>
        <GradientStop Color="#141C2A" Offset="1"/>
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="ReferencePrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4EA7FF" Offset="0"/>
        <GradientStop Color="#1D6FD9" Offset="1"/>
      </LinearGradientBrush>

      <Style x:Key="HeaderChipStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="BorderBrush" Value="#4168A1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#2A4D84"/>
      </Style>

      <Style x:Key="UpdateSectionToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource PageFilterToggleStyle}">
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      </Style>

      <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
      </Style>

      <Style x:Key="SlimComboStyle" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Foreground" Value="#E8F1FF"/>
        <Setter Property="Background" Value="#203C66"/>
        <Setter Property="BorderBrush" Value="#3D6398"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,0,36,0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="ItemContainerStyle">
          <Setter.Value>
            <Style TargetType="ComboBoxItem">
              <Setter Property="Foreground" Value="#E8F1FF"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Padding" Value="10,6"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Margin="4,2">
                      <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="ItemRoot" Property="Background" Value="#2A4469"/>
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="ItemRoot" Property="Background" Value="#345988"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </Setter.Value>
        </Setter>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ComboBox">
              <Grid>
                <ToggleButton Focusable="False"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              ClickMode="Press"
                              Background="Transparent"
                              BorderBrush="Transparent">
                  <Border x:Name="ComboBorder"
                          CornerRadius="11"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          Background="{TemplateBinding Background}">
                    <Grid>
                      <ContentPresenter Margin="12,0,30,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Content="{TemplateBinding SelectionBoxItem}"/>
                      <TextBlock FontFamily="Segoe MDL2 Assets"
                                 Text="&#xE70D;"
                                 FontSize="10"
                                 Foreground="#CFE4FF"
                                 HorizontalAlignment="Right"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </ToggleButton>

                <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       PopupAnimation="Slide">
                  <Border Margin="0,4,0,0"
                          CornerRadius="10"
                          BorderBrush="#405D88"
                          BorderThickness="1"
                          Background="#18253A"
                          MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                    <ScrollViewer MaxHeight="300">
                      <ItemsPresenter/>
                    </ScrollViewer>
                  </Border>
                </Popup>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ComboBorder" Property="Background" Value="#284A7A"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                  <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#79BAFF"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="ReferencePrimaryButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="Background" Value="{StaticResource ReferencePrimaryButtonBrush}"/>
        <Setter Property="Foreground" Value="#F7FBFF"/>
        <Setter Property="BorderBrush" Value="#86CBFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Root"
                      CornerRadius="11"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Root" Property="Opacity" Value="0.84"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="ReferenceSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Background" Value="#2B374E"/>
        <Setter Property="Foreground" Value="#DDE9FB"/>
        <Setter Property="BorderBrush" Value="#475A7A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Root"
                      CornerRadius="11"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Root" Property="Background" Value="#334560"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Root" Property="Opacity" Value="0.86"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </UserControl.Resources>

  <Border x:Name="RootHost" Background="{DynamicResource AppBackgroundBrush}" DataContext="{Binding HostedContent}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Margin="0,0,0,12"
              Padding="18"
              CornerRadius="14"
              BorderBrush="#78AFFF"
              BorderThickness="1"
              Background="{StaticResource UpdateHeroBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock Text="Update Center"
                       Style="{StaticResource H1}"
                       FontSize="30"/>
            <TextBlock Margin="0,4,0,0"
                       Text="Software-, Sicherheits- und optionale Updates getrennt steuern."
                       Style="{StaticResource BodyStyle}"
                       Foreground="#D5E9FF"/>
            <Border Margin="0,10,0,0"
                    Padding="10,6"
                    CornerRadius="9"
                    BorderBrush="{DynamicResource StatusWarnBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource StatusWarnBgBrush}"
                    Visibility="{Binding HasCriticalSecurityHint, Converter={StaticResource BoolToVisibilityConverter}}">
              <TextBlock Text="{Binding CriticalSecurityHintText}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextBrush}"/>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
            <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,10">
              <Border Style="{StaticResource HeaderChipStyle}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                             Text="&#xE73E;"
                             Margin="0,0,7,0"
                             FontSize="14"
                             Foreground="#7BE0B9"/>
                  <TextBlock Style="{StaticResource Small}"
                             Foreground="#CFE7FF">
                    <Run Text="{Binding HeaderTotalCount, Mode=OneWay}"/>
                    <Run Text=" Updates"/>
                  </TextBlock>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChipStyle}">
                <TextBlock Style="{StaticResource Small}" Foreground="#D8EAFF">
                  <Run Text="{Binding HeaderSecurityCount, Mode=OneWay}"/>
                  <Run Text=" normal "/>
                  <Run Text="{Binding TotalDownloadSizeText, Mode=OneWay}" Foreground="#FFD27A"/>
                </TextBlock>
              </Border>
              <Border Style="{StaticResource HeaderChipStyle}">
                <TextBlock Text="{Binding UpdateUrgencyHint}"
                           Style="{StaticResource Small}"
                           Foreground="#D8EAFF"/>
              </Border>
            </WrapPanel>

            <Button MinWidth="240"
                    Content="{Binding HeaderInstallButtonText}"
                    Command="{Binding InstallFromHeaderCommand}"
                    Style="{StaticResource ReferencePrimaryButtonStyle}"/>
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Style="{StaticResource CardStyle}"
              Margin="0,0,0,12"
              Background="{StaticResource UpdatePanelBrush}"
              BorderBrush="#354765"
              Padding="12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370"/>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                  Margin="0,0,10,0"
                  CornerRadius="12"
                  BorderBrush="#4A77B8"
                  BorderThickness="1">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2B5FA8" Offset="0"/>
                <GradientStop Color="#294D88" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="&#xE721;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="20"
                         Margin="14,0,10,0"
                         Foreground="#E5F1FF"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="1"
                       Style="{StaticResource SearchBoxStyle}"
                       Text="{Binding SoftwareSearchText, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="Suche nach Software..."/>
              <Button Grid.Column="2"
                      Width="18"
                      Height="18"
                      Margin="0,0,6,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderBrush="Transparent"
                      Command="{Binding ClearSoftwareSearchCommand}"
                      Visibility="{Binding HasSoftwareSearchText, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Foreground="#DDEBFF"/>
              </Button>
              <TextBlock Grid.Column="3"
                         FontFamily="Segoe MDL2 Assets"
                         Text="&#xE70D;"
                         FontSize="10"
                         Margin="8,0,14,0"
                         Foreground="#DDEBFF"
                         VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <ComboBox Grid.Column="1"
                    Margin="0,0,10,0"
                    Style="{StaticResource SlimComboStyle}"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilterOption}"
                    DisplayMemberPath="Label"/>

          <ComboBox Grid.Column="2"
                    Margin="0,0,10,0"
                    Style="{StaticResource SlimComboStyle}"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption}"
                    DisplayMemberPath="Label"/>

          <StackPanel Grid.Column="3" Orientation="Horizontal">
            <Button Content="Alle markieren"
                    Margin="0,0,8,0"
                    Command="{Binding SelectAllCommand}"
                    Style="{StaticResource ReferenceSecondaryButtonStyle}"/>
            <Button Content="Auswahl aufheben"
                    Margin="0,0,8,0"
                    Command="{Binding ClearSelectionCommand}"
                    Style="{StaticResource ReferenceSecondaryButtonStyle}"/>
            <Button Content="Aktualisieren"
                    Command="{Binding RefreshUpdatesCommand}"
                    Style="{StaticResource ReferenceSecondaryButtonStyle}"/>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="252"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Bereich" Style="{StaticResource H2}" FontSize="17"/>
            <TextBlock Text="Wähle links den Update-Typ."
                       Margin="0,4,0,10"
                       Style="{StaticResource Small}"/>

            <ToggleButton Style="{StaticResource UpdateSectionToggleStyle}"
                          IsChecked="{Binding IsSoftwareSectionSelected, Mode=OneWay}"
                          Command="{Binding SelectSectionCommand}"
                          CommandParameter="software">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Software Updates" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Border Grid.Column="2" Style="{StaticResource StatusBadgeInfo}" VerticalAlignment="Center">
                  <TextBlock Text="{Binding SoftwareSectionBadgeCount}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                </Border>
              </Grid>
            </ToggleButton>

            <ToggleButton Style="{StaticResource UpdateSectionToggleStyle}"
                          IsChecked="{Binding IsWindowsSectionSelected, Mode=OneWay}"
                          Command="{Binding SelectSectionCommand}"
                          CommandParameter="windows">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Windows Updates" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Border Grid.Column="2" Style="{StaticResource StatusBadgeInfo}" VerticalAlignment="Center">
                  <TextBlock Text="{Binding WindowsSectionBadgeCount}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                </Border>
              </Grid>
            </ToggleButton>

            <ToggleButton Style="{StaticResource UpdateSectionToggleStyle}"
                          IsChecked="{Binding IsOptionalSectionSelected, Mode=OneWay}"
                          Command="{Binding SelectSectionCommand}"
                          CommandParameter="optional">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Optionale Updates" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Border Grid.Column="2" Style="{StaticResource StatusBadgeInfo}" VerticalAlignment="Center">
                  <TextBlock Text="{Binding OptionalSectionBadgeCount}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusInfoBrush}"/>
                </Border>
              </Grid>
            </ToggleButton>

            <Border Style="{StaticResource SoftLine}" Margin="0,4,0,8"/>
            <TextBlock Text="{Binding SoftwareStatusHint}" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Visibility="{Binding IsSoftwareSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <Expander Margin="0,0,0,10" IsExpanded="{Binding IsSecurityGroupExpanded}">
                <Expander.Header>
                  <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal">
                      <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusCritBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding SecurityGroupTitle}" FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                  </DockPanel>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding SecurityUpdates}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:UpdateCardV2 Item="{Binding}"
                                             InstallCommand="{Binding DataContext.InstallOneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             ToggleDetailsCommand="{Binding DataContext.ToggleExpandDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             ShowDetailsCommand="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Expander>

              <Expander Margin="0,0,0,10" IsExpanded="{Binding IsRecommendedGroupExpanded}">
                <Expander.Header>
                  <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusInfoBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RecommendedGroupTitle}" FontSize="20" FontWeight="SemiBold"/>
                  </StackPanel>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding RecommendedUpdates}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:UpdateCardV2 Item="{Binding}"
                                             InstallCommand="{Binding DataContext.InstallOneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             ToggleDetailsCommand="{Binding DataContext.ToggleExpandDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             ShowDetailsCommand="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Expander>

              <Expander IsExpanded="{Binding IsOptionalGroupExpanded}">
                <Expander.Header>
                  <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource StatusWarnBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OptionalGroupTitle}" FontSize="20" FontWeight="SemiBold"/>
                  </StackPanel>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding OptionalUpdates}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:UpdateCardV2 Item="{Binding}"
                                             InstallCommand="{Binding DataContext.InstallOneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             ToggleDetailsCommand="{Binding DataContext.ToggleExpandDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             ShowDetailsCommand="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Expander>

              <Border Margin="0,10,0,0"
                      Padding="12"
                      CornerRadius="10"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      Visibility="{Binding HasFilteredSoftwareUpdates, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <TextBlock Text="Keine Updates gefunden."
                           Style="{StaticResource BodyStyle}"
                           TextAlignment="Center"/>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Visibility="{Binding IsWindowsSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel>
              <TextBlock Text="Windows Updates" Style="{StaticResource SectionTitle}"/>
              <Button DockPanel.Dock="Right"
                      Content="Windows Updates installieren"
                      Style="{StaticResource ReferencePrimaryButtonStyle}"
                      Command="{Binding InstallSecurityUpdatesCommand}"/>
            </DockPanel>
            <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding WindowsCombinedFindings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="10">
                      <controls:FindingRowControl/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Visibility="{Binding IsOptionalSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel>
              <TextBlock Text="Optionale Updates" Style="{StaticResource SectionTitle}"/>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Optionale installieren"
                        Margin="0,0,8,0"
                        Style="{StaticResource ReferencePrimaryButtonStyle}"
                        Command="{Binding InstallOptionalUpdatesCommand}"/>
                <Button Content="Treiberseite"
                        Style="{StaticResource ReferenceSecondaryButtonStyle}"
                        Command="{Binding OpenDriverUpdatesCommand}"/>
              </StackPanel>
            </DockPanel>
            <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding OptionalCombinedFindings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="10">
                      <controls:FindingRowControl/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Border>
</UserControl>
