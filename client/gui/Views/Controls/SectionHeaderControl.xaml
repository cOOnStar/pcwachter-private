<UserControl x:Class="PCWachter.Desktop.Views.Controls.SectionHeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel Margin="0,0,0,12">
        <TextBlock Text="{Binding Title, ElementName=Root}" Style="{StaticResource SectionTitle}"/>
        <TextBlock Text="{Binding Subtitle, ElementName=Root}" Style="{StaticResource BodyStyle}" Margin="0,4,0,0" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
