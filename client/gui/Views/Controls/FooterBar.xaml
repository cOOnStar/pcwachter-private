<UserControl x:Class="PCWachter.Desktop.Views.Controls.FooterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:data="clr-namespace:System.Windows.Data;assembly=PresentationFramework">

  <UserControl.Resources>
    <CollectionViewSource x:Key="GroupedNotificationsView"
                          Source="{Binding FilteredNotifications}">
      <CollectionViewSource.GroupDescriptions>
        <data:PropertyGroupDescription PropertyName="GroupLabel"/>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>

    <Style x:Key="FooterLabelStyle" TargetType="Run">
      <Setter Property="Foreground" Value="#B5C2D8"/>
      <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <Style x:Key="FooterValueStyle" TargetType="Run">
      <Setter Property="Foreground" Value="#E6EEFC"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="FooterIconButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="24"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="#223247"/>
      <Setter Property="BorderBrush" Value="#3D4D66"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    CornerRadius="12"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#2B4160"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.86"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FooterReconnectButtonStyle" TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
      <Setter Property="Content" Value="Erneut verbinden"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="MinWidth" Value="138"/>
      <Setter Property="Visibility" Value="Collapsed"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsServiceDisconnected}" Value="True">
          <Setter Property="Visibility" Value="Visible"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1180}" Value="True">
          <Setter Property="Content" Value="Verbinden"/>
          <Setter Property="MinWidth" Value="106"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1040}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="NotificationFilterToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource PageFilterToggleStyle}">
      <Setter Property="Padding" Value="8,3"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <Style x:Key="FooterIconPlaceholderStyle" TargetType="Border">
      <Setter Property="Width" Value="24"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Background" Value="#223247"/>
      <Setter Property="BorderBrush" Value="#3D4D66"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="FooterFullTextStyle" TargetType="TextBlock">
      <Setter Property="Visibility" Value="Visible"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1250}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="FooterMediumTextStyle" TargetType="TextBlock">
      <Setter Property="Visibility" Value="Collapsed"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1250}" Value="True">
          <Setter Property="Visibility" Value="Visible"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=980}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="FooterCompactTextStyle" TargetType="TextBlock">
      <Setter Property="Visibility" Value="Collapsed"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=980}" Value="True">
          <Setter Property="Visibility" Value="Visible"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid Margin="14,0,14,0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" VerticalAlignment="Center">
      <TextBlock FontSize="13" TextTrimming="CharacterEllipsis" Style="{StaticResource FooterFullTextStyle}">
        <Run Style="{StaticResource FooterLabelStyle}" Text="Letzter Scan: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding LastScanDisplay, Mode=OneWay}"/>
        <Run Style="{StaticResource FooterLabelStyle}" Text=" | Version: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding ProgramVersionDisplay, Mode=OneWay}"/>
        <Run Style="{StaticResource FooterLabelStyle}" Text=" | Konto: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding AccountStatusDisplay, Mode=OneWay}"/>
        <Run Style="{StaticResource FooterLabelStyle}" Text=" | Servicestatus: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding FooterServiceStatusDisplay, Mode=OneWay}"/>
      </TextBlock>

      <TextBlock FontSize="13" TextTrimming="CharacterEllipsis" Style="{StaticResource FooterMediumTextStyle}">
        <Run Style="{StaticResource FooterLabelStyle}" Text="Letzter Scan: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding LastScanDisplay, Mode=OneWay}"/>
        <Run Style="{StaticResource FooterLabelStyle}" Text=" | Konto: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding AccountStatusDisplay, Mode=OneWay}"/>
        <Run Style="{StaticResource FooterLabelStyle}" Text=" | Servicestatus: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding FooterServiceStatusDisplay, Mode=OneWay}"/>
      </TextBlock>

      <TextBlock FontSize="13" TextTrimming="CharacterEllipsis" Style="{StaticResource FooterCompactTextStyle}">
        <Run Style="{StaticResource FooterLabelStyle}" Text="Scan: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding LastScanDisplay, Mode=OneWay}"/>
        <Run Style="{StaticResource FooterLabelStyle}" Text=" | Status: "/>
        <Run Style="{StaticResource FooterValueStyle}" Text="{Binding FooterServiceStatusDisplay, Mode=OneWay}"/>
      </TextBlock>
    </Grid>

    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
      <Button Style="{StaticResource FooterReconnectButtonStyle}"
              Command="{Binding RetryConnectionCommand}"/>

      <Grid>
        <Button x:Name="NotificationBellButton"
                Style="{StaticResource FooterIconButtonStyle}"
                Command="{Binding ToggleNotificationCenterCommand}"
                ToolTip="Benachrichtigungscenter">
          <TextBlock Text="&#xE7ED;"
                     FontFamily="Segoe MDL2 Assets"
                     FontSize="13"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="#DCE6F8"/>
        </Button>

        <Border Width="14"
                Height="14"
                CornerRadius="7"
                Background="{DynamicResource StatusCritBrush}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-4,-2,0"
                Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
          <TextBlock Text="{Binding UnreadNotificationCount}"
                     Foreground="White"
                     FontSize="9"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Popup PlacementTarget="{Binding ElementName=NotificationBellButton}"
               Placement="Top"
               HorizontalOffset="-250"
               VerticalOffset="-10"
               AllowsTransparency="True"
               StaysOpen="False"
               IsOpen="{Binding IsNotificationCenterOpen, Mode=TwoWay}">
          <Border Width="360"
                  MaxHeight="420"
                  Background="#111A28"
                  BorderBrush="#3D4D66"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="12"
                  SnapsToDevicePixels="True">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="6"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Benachrichtigungen"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button Grid.Column="1"
                        Content="Alle gelesen"
                        Command="{Binding MarkAllNotificationsReadCommand}"
                        Style="{StaticResource BtnSecondary}"
                        Padding="8,3"
                        FontSize="11"/>
                <Button Grid.Column="3"
                        Content="Leeren"
                        Command="{Binding ClearNotificationsCommand}"
                        Style="{StaticResource BtnSecondary}"
                        Padding="8,3"
                        FontSize="11"/>
              </Grid>

              <WrapPanel Grid.Row="2">
                <ToggleButton Style="{StaticResource NotificationFilterToggleStyle}"
                              Content="{Binding NotificationFilterAllLabel}"
                              IsChecked="{Binding IsNotificationFilterAllSelected, Mode=OneWay}"
                              Command="{Binding SetNotificationFilterCommand}"
                              CommandParameter="all"/>
                <ToggleButton Style="{StaticResource NotificationFilterToggleStyle}"
                              Content="{Binding NotificationFilterUnreadLabel}"
                              IsChecked="{Binding IsNotificationFilterUnreadSelected, Mode=OneWay}"
                              Command="{Binding SetNotificationFilterCommand}"
                              CommandParameter="unread"/>
                <ToggleButton Style="{StaticResource NotificationFilterToggleStyle}"
                              Content="{Binding NotificationFilterImportantLabel}"
                              IsChecked="{Binding IsNotificationFilterImportantSelected, Mode=OneWay}"
                              Command="{Binding SetNotificationFilterCommand}"
                              CommandParameter="important"/>
              </WrapPanel>

              <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                  <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedNotificationsView}}"
                                Visibility="{Binding HasFilteredNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.GroupStyle>
                      <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                          <DataTemplate>
                            <TextBlock Margin="0,2,0,8"
                                       Text="{Binding Name}"
                                       Style="{StaticResource Small}"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                          </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                      </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="9,8"
                                CornerRadius="8"
                                BorderThickness="1"
                                Background="#1A2536"
                                BorderBrush="#32415B"
                                Opacity="0">
                          <Border.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                              <BeginStoryboard>
                                <Storyboard>
                                  <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                   From="0"
                                                   To="1"
                                                   Duration="0:0:0.16"/>
                                </Storyboard>
                              </BeginStoryboard>
                            </EventTrigger>
                          </Border.Triggers>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="22"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Text" Value="&#xE946;"/>
                                  <Setter Property="Foreground" Value="{DynamicResource StatusInfoBrush}"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="warning">
                                      <Setter Property="Text" Value="&#xE7BA;"/>
                                      <Setter Property="Foreground" Value="{DynamicResource StatusWarnBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="critical">
                                      <Setter Property="Text" Value="&#xEA39;"/>
                                      <Setter Property="Foreground" Value="{DynamicResource StatusCritBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="success">
                                      <Setter Property="Text" Value="&#xE73E;"/>
                                      <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                              <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding Title}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding TimeText}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11"/>
                              </DockPanel>
                              <TextBlock Text="{Binding Message}"
                                         Margin="0,3,0,0"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         TextWrapping="Wrap"/>
                              <Button Margin="0,8,0,0"
                                      Padding="10,4"
                                      FontSize="11"
                                      Content="{Binding ActionLabel}"
                                      Command="{Binding ActionCommand}"
                                      Style="{StaticResource BtnPrimary}"
                                      HorizontalAlignment="Left"
                                      Visibility="{Binding HasAction, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border CornerRadius="8"
                          Padding="10,12"
                          BorderThickness="1"
                          Background="#1A2536"
                          BorderBrush="#32415B"
                          Visibility="{Binding HasFilteredNotifications, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <TextBlock Text="Keine Benachrichtigungen im gewählten Filter."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center"/>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Border>
        </Popup>
      </Grid>

      <Border Style="{StaticResource FooterIconPlaceholderStyle}" ToolTip="{Binding LiveModeLabel, StringFormat=Modus: {0}}">
        <TextBlock Text="&#xE9D9;"
                   FontFamily="Segoe MDL2 Assets"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#DCE6F8"/>
      </Border>
      <Border Width="24"
              Height="24"
              CornerRadius="12"
              Background="#223247"
              BorderBrush="#3D4D66"
              BorderThickness="1">
        <TextBlock Text="&#xE946;"
                   FontFamily="Segoe MDL2 Assets"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#DCE6F8"/>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>

