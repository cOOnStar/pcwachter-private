<UserControl x:Class="PCWachter.Desktop.Views.Controls.ProgressOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             IsHitTestVisible="{Binding IsActive, ElementName=Root}">
  <Grid x:Name="OverlayRoot"
        Background="#96050A12"
        Visibility="{Binding IsActive, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
        Opacity="1">

    <Border Width="380"
            Padding="18"
            CornerRadius="16"
            Background="#E61A2636"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Effect="{DynamicResource ShadowOverlay}">
      <Border.RenderTransform>
        <ScaleTransform x:Name="OverlayScale" ScaleX="1" ScaleY="1"/>
      </Border.RenderTransform>

      <StackPanel>
        <TextBlock Text="Bitte warten..." Style="{StaticResource H2}" FontSize="18"/>
        <TextBlock Text="{Binding Message, ElementName=Root}"
                   Margin="0,8,0,0"
                   Style="{StaticResource BodyStyle}"
                   TextWrapping="Wrap"/>
        <ProgressBar IsIndeterminate="True" Height="8" Margin="0,14,0,0"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
