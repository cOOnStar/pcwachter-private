<Window x:Class="PCWachter.Desktop.Views.Windows.UpdateDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="760"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#101825"
        Foreground="#EAF1FB">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PCWachter.Desktop;component/Themes/Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
      <TextBlock Margin="0,6,0,0" Text="{Binding SourceLabel}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBlock Margin="0,3,0,0" Text="{Binding SeverityLabel, StringFormat=Priorität: {0}}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBlock Margin="0,3,0,0" Text="{Binding RestartHint}" Style="{StaticResource Small}" Foreground="{DynamicResource StatusWarnBrush}"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="0,14,0,14" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="Zusammenfassung" FontWeight="SemiBold" FontSize="16"/>
        <TextBlock Margin="0,6,0,0" Text="{Binding Summary}" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>

        <TextBlock Margin="0,14,0,0" Text="Empfohlenes Vorgehen" FontWeight="SemiBold" FontSize="16"/>
        <TextBlock Margin="0,6,0,0" Text="{Binding RecommendedAction}" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>

        <TextBlock Margin="0,14,0,0" Text="Release Notes / Details" FontWeight="SemiBold" FontSize="16"/>
        <TextBlock Margin="0,6,0,0" Text="{Binding ReleaseNotes}" Style="{StaticResource Small}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
    </ScrollViewer>

    <DockPanel Grid.Row="2" LastChildFill="False">
      <Button DockPanel.Dock="Right"
              MinWidth="120"
              Padding="14,7"
              Content="Schliessen"
              Style="{StaticResource PrimaryButtonStyle}"
              IsCancel="True"/>
    </DockPanel>
  </Grid>
</Window>

