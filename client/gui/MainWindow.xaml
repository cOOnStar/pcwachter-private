<Window x:Class="PCWachter.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:PCWachter.Desktop.Views.Controls"
        xmlns:pages="clr-namespace:PCWachter.Desktop.Views.Pages"
        xmlns:viewModels="clr-namespace:PCWachter.Desktop.ViewModels"
        Title="PCW&#228;chter"
        Width="1420"
        Height="890"
        WindowStartupLocation="CenterScreen"
        Background="#0B111B"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="CanResize"
        WindowStyle="None">

  <Window.Resources>
    <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#111926" Offset="0"/>
      <GradientStop Color="#0B111B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NavBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#1A2536" Offset="0"/>
      <GradientStop Color="#121B28" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="WindowFrameBorder" TargetType="Border">
      <Setter Property="BorderBrush" Value="#2A3342"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IsActive}" Value="False">
          <Setter Property="BorderBrush" Value="#1D2430"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
          <Setter Property="BorderThickness" Value="0"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="WindowControlButton" TargetType="Button">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#D5DEEE"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Hit" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Hit" Property="Background" Value="#19FFFFFF"/>
              </Trigger>
              <Trigger Property="Tag" Value="Close">
                <Setter Property="Foreground" Value="#F2F6FF"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="Tag" Value="Close"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Hit" Property="Background" Value="#C42B1C"/>
              </MultiTrigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Hit" Property="Opacity" Value="0.88"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
      <pages:DashboardPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:SecurityViewModel}">
      <pages:SecurityPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:WindowsViewModel}">
      <pages:WindowsPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:UpdatesFluentPageViewModel}">
      <pages:UpdatesFluentPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:StorageFluentPageViewModel}">
      <pages:StorageFluentPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:StorageViewModel}">
      <pages:StoragePage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:NetworkViewModel}">
      <pages:NetworkPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:HistoryViewModel}">
      <pages:HistoryPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:AccountViewModel}">
      <pages:AccountPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:OptionsViewModel}">
      <pages:OptionsPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:HelpViewModel}">
      <pages:HelpPage/>
    </DataTemplate>
  </Window.Resources>

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="40"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Grid Background="{StaticResource ShellBackgroundBrush}">
    <Border x:Name="AppShellBorder"
            Style="{StaticResource WindowFrameBorder}"
            Margin="0"
            CornerRadius="0"
            Background="{StaticResource ShellBackgroundBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="40"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="42"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                BorderBrush="#2B3648"
                BorderThickness="0,0,0,1">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
              <GradientStop Color="#1B2A3E" Offset="0"/>
              <GradientStop Color="#2D4767" Offset="0.5"/>
              <GradientStop Color="#1B2A3E" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Height="1"
                VerticalAlignment="Top"
                Background="#8EAED5"
                Opacity="0.38"
                IsHitTestVisible="False"/>

        <Border Grid.Row="0"
                Grid.Column="0"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
          <Grid>
            <TextBlock Text="PCW&#228;chter"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="#ECF3FF"/>
          </Grid>
        </Border>

        <StackPanel Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button Style="{StaticResource WindowControlButton}"
                  Click="Min_Click"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  AutomationProperties.Name="Fenster minimieren">
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE921;"/>
          </Button>
          <Button Style="{StaticResource WindowControlButton}"
                  Click="Max_Click"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  AutomationProperties.Name="Fenster maximieren oder wiederherstellen">
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE922;"/>
          </Button>
          <Button Style="{StaticResource WindowControlButton}"
                  Tag="Close"
                  Click="Close_Click"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  AutomationProperties.Name="Fenster schließen">
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/>
          </Button>
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#0A111B"
                Padding="16,14,16,12">
          <Grid>
            <ContentControl x:Name="MainContentHost" Content="{Binding CurrentPage}"/>

            <Border Background="#AA0A111B"
                    CornerRadius="10"
                    Width="320"
                    Height="120"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Background" Value="#AA0A111B"/>
                  <Setter Property="Visibility" Value="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnectingToService}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="220" Height="8" IsIndeterminate="True"/>
                <TextBlock Margin="0,14,0,0"
                           Text="{Binding BusyMessage}"
                           Foreground="#E8F0FF"
                           FontSize="13"
                           TextAlignment="Center"/>
              </StackPanel>
            </Border>

          </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="{StaticResource NavBackgroundBrush}"
                BorderBrush="#3B485F"
                BorderThickness="1,0,0,0">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="{StaticResource NavBackgroundBrush}"/>
              <Setter Property="BorderBrush" Value="#3B485F"/>
              <Setter Property="BorderThickness" Value="1,0,0,0"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1160}" Value="True">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderThickness" Value="0"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <controls:NavigationPane>
            <controls:NavigationPane.Style>
              <Style TargetType="{x:Type controls:NavigationPane}">
                <Setter Property="Width" Value="248"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1320}" Value="True">
                    <Setter Property="Width" Value="196"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource LessThanConverter}, ConverterParameter=1160}" Value="True">
                    <Setter Property="Width" Value="40"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </controls:NavigationPane.Style>
          </controls:NavigationPane>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#101825"
                BorderBrush="#3A465B"
                BorderThickness="0,1,0,0">
          <controls:FooterBar/>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
